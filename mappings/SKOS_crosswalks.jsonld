      ]
    },
  {
      "@id": "datacite:date",
      "@type": "skos:Concept",
      "skos:prefLabel": "Date",
      "skos:definition": "Different dates relevant to the work.",
      "skos:exactMatch": { "@id": "dcterms:date" },
      "skos:broadMatch": [
    { "@id": "schema:dateCreated" },
    { "@id": "schema:datePublished" },
