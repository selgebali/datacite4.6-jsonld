      "skos:exactMatch": { "@id": "schema:identifier" },
      "skos:closeMatch": [
        { "@id": "dcat:identifier" },
      { "@id": "wd:Q853614" }
 ],
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
    {
      "@id": "datacite:affiliationIdentifierScheme",
      "@type": "skos:Concept",
      "skos:prefLabel": "Affiliation Identifier Scheme",
      "skos:definition": "The scheme used for the affiliation identifier.",
      "skos:exactMatch": { "@id": "schema:PropertyValue.propertyID" },
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
    {
      "@id": "datacite:affiliationSchemeURI",
      "@type": "skos:Concept",
      "skos:prefLabel": "Affiliation Scheme URI",
      "skos:definition": "The URL identifying the affiliation identifier scheme.",
      "skos:exactMatch": { "@id": "schema:PropertyValue.propertyURL" },
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
    {
      "@id": "datacite:title",
      "@type": "skos:Concept",
      "skos:prefLabel": "Title",
      "skos:definition": "The main title of the resource.",
      "skos:exactMatch": [
        { "@id": "schema:name" },
        { "@id": "dcterms:title" },
        { "@id": "wd:Q783521" }
      ],
      "skos:narrowMatch": { "@id": "schema:headline" },
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
{
  "@id": "datacite:titleType",
  "@type": "skos:Concept",
  "skos:prefLabel": "Title Type",
  "skos:definition": "The type of title element other than the main title.",
  "skos:exactMatch": { "@id": "schema:PropertyValue.propertyID" },
  "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
},

{
      "@id": "datacite:TitleTypeScheme",
      "@type": "skos:ConceptScheme",
      "skos:prefLabel": "DataCite TitleType Scheme",
      "skos:definition": "Controlled list of DataCite titleType values.",
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" },
      "skos:hasTopConcept": [
        { "@id": "datacite:TitleType_AlternativeTitle" },
        { "@id": "datacite:TitleType_Subtitle" },
        { "@id": "datacite:TitleType_TranslatedTitle" },
        { "@id": "datacite:TitleType_Other" }
      ]
    },
    
    {
      "@id": "datacite:TitleType_AlternativeTitle",
      "@type": "skos:Concept",
      "skos:prefLabel": "AlternativeTitle",
      "skos:definition": "An alternate title of the resource.",
      "skos:exactMatch": [
        { "@id": "schema:alternativeHeadline" },
        { "@id": "dcterms:title" }
      ],
      "skos:closeMatch": { "@id": "wd:Q4736562" },
      "skos:broader": { "@id": "datacite:titleType" },
      "skos:inScheme": { "@id": "datacite:TitleTypeScheme" }
    },

{
      "@id": "datacite:TitleType_Subtitle",
      "@type": "skos:Concept",
      "skos:prefLabel": "Subtitle",
      "skos:definition": "A subtitle of the resource.",
      "skos:exactMatch": [
        { "@id": "schema:alternativeHeadline" },
        { "@id": "dcterms:title" }
      ],
      "skos:closeMatch": { "@id": "wd:Q1135389" },
      "skos:broader": { "@id": "datacite:titleType" },
      "skos:inScheme": { "@id": "datacite:TitleTypeScheme" }
    },
{
    "@id": "datacite:TitleType_TranslatedTitle",
    "@type": "skos:Concept",
    "skos:prefLabel": "TranslatedTitle",
    "skos:definition": "A translated title of the resource.",
    "skos:relatedMatch": [
    { "@id": "schema:workTranslation" },
    { "@id": "wd:Q7553" }
  ],
  "skos:broader": {
    "@id": "datacite:titleType"
  },
  "skos:inScheme": {
    "@id": "datacite:TitleTypeScheme"
  }
},

{
      "@id": "datacite:TitleType_Other",
