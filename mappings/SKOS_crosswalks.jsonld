    },
{
      "@id": "datacite:ResourceTypeGeneral_StudyRegistration",
      "@type": "skos:Concept",
      "skos:prefLabel": "StudyRegistration",
      "skos:definition": "A detailed, time-stamped description of a research plan, often openly shared in a registry or published in a journal before the study is conducted to lend accountability and transparency in the hypothesis generating and testing process.",
      "skos:closeMatch": { "@id": "dcterms:Text" },
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
