      "skos:closeMatch": { "@id": "wd:Q46135267" },
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
 {
      "@id": "datacite:affiliationIdentifier",
      "@type": "skos:Concept",
      "skos:prefLabel": "Affiliation Identifier",
