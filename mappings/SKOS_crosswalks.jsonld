        { "@id": "datacite:ResourceTypeGeneral_Text" },
        { "@id": "datacite:ResourceTypeGeneral_Workflow" },
        { "@id": "datacite:ResourceTypeGeneral_Other" }
      ]
    },
    {
      "@id": "datacite:resourceType",
      "@type": "skos:Concept",
      "skos:prefLabel": "Resource Type",
      "skos:definition": "A description of the resource.",
     "skos:exactMatch": [
        { "@id": "schema:description" },
        { "@id": "wd:Q22097967" },
        { "@id": "dcterms:type" }
  ],
      "skos:closeMatch": { "@id": "dcat:resource" },
      "skos:relatedMatch":[
         { "@id": "datacite:resourceTypeGeneral" },
         {"@id":"schema:additionalType"}
      ],
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
    {
      "@id": "datacite:resourceTypeGeneral",
      "@type": "skos:Concept",
      "skos:prefLabel": "Resource Type General",
      "skos:definition": "The general type of a resource.",
      "skos:exactMatch": [
            { "@id": "schema:genre" },
            { "@id": "dcterms:type" }
  ],

      "skos:relatedMatch": { "@id": "datacite:resourceType" },
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_Audiovisual",
      "@type": "skos:Concept",
      "skos:prefLabel": "Audiovisual",
      "skos:definition": "A series of visual representations imparting an impression of motion when shown in succession. May or may not include sound.",
      "skos:exactMatch": [
          { "@id": "schema:MediaObject" },
          { "@id": "dcterms:MovingImage" },
          { "@id": "wd:Q758901" }
  ],
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_Award",
      "@type": "skos:Concept",
      "skos:prefLabel": "Award",
      "skos:definition": "An umbrella term for resources provided to individual(s) or organization(s) in support of research, academic output, or training, such as a specific instance of funding, grant, investment, sponsorship, scholarship, recognition, or non-monetary materials.",
      "skos:exactMatch": { "@id": "wd:Q618779" },
      "skos:closeMatch": { "@id": "schema:CreativeWork" },
      "skos:narrowMatch": { "@id": "schema:Grant" },
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_Book",
      "@type": "skos:Concept",
      "skos:prefLabel": "Book",
      "skos:definition": "A medium for recording information in the form of writing or images, typically composed of many pages bound together and protected by a cover.",
      "skos:exactMatch": [
          { "@id": "schema:Book" },
          { "@id": "wd:Q571" }
  ],
      "skos:broadMatch":  { "@id": "dcterms:BibliographicResource" },
      "skos:closeMatch": { "@id": "dcterms:Text" },
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_BookChapter",
      "@type": "skos:Concept",
      "skos:prefLabel": "BookChapter",
      "skos:definition": "One of the main divisions of a book.",
      "skos:exactMatch": [
          { "@id": "schema:Chapter" },
          { "@id": "wd:Q1980247" }
  ],
      "skos:closeMatch": { "@id": "dcterms:Text" },
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_Collection",
      "@type": "skos:Concept",
      "skos:prefLabel": "Collection",
      "skos:definition": " An aggregation of resources, which may encompass collections of one resourceType as well as those of mixed types. A collection is described as a group; its parts may also be separately described.",
      "skos:exactMatch": [
          { "@id": "schema:Collection" },
          { "@id": "dcterms:Collection" },
          { "@id": "wd:Q2668072" }
  ],
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_ComputationalNotebook",
      "@type": "skos:Concept",
      "skos:prefLabel": "ComputationalNotebook",
      "skos:definition": "A virtual notebook environment used for literate programming (e.g., Jupyter Notebook).",
      "skos:exactMatch": [
          { "@id": "schema:SoftwareApplication" },
          { "@id": "dcterms:Software" },
          { "@id": "wd:Q28405706" }
  ],
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_ConferencePaper",
      "@type": "skos:Concept",
      "skos:prefLabel": "ConferencePaper",
      "skos:definition": "Article that is written with the goal of being accepted to a conference.",
      "skos:exactMatch": [
          { "@id": "schema:ScholarlyArticle" },
          { "@id": "wd:Q23927052" }
      ],
      "skos:broadMatch": [
        { "@id": "dcterms:BibliographicResource" }
      ],
      "skos:closeMatch": { "@id": "dcterms:Text" },
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_ConferenceProceeding",
      "@type": "skos:Concept",
      "skos:prefLabel": "ConferenceProceeding",
      "skos:definition": "Collection of academic papers published in the context of an academic conference.",
      "skos:exactMatch": [
          { "@id": "schema:PublicationVolume" },
          { "@id": "wd:Q1143604" }
      ],
      "skos:closeMatch": { "@id": "dcterms:Text" },
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
  "@id": "datacite:ResourceTypeGeneral_DataPaper",
  "@type": "skos:Concept",
  "skos:prefLabel": "DataPaper",
  "skos:definition": "A factual and objective publication with a focused intent to identify and describe specific data, sets of data, or data collections to facilitate discoverability.",
  "skos:exactMatch": [
    { "@id": "wd:Q17009938" },
    { "@id": "schema:ScholarlyArticle" }
  ],
  "skos:closeMatch": { "@id": "dcterms:Text" } ,
  "skos:broadMatch": { "@id": "dcterms:BibliographicResource" },
  "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
  "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
},
    {
      "@id": "datacite:ResourceTypeGeneral_Dataset",
      "@type": "skos:Concept",
      "skos:prefLabel": "Dataset",
      "skos:definition": "Data encoded in a defined structure.",
      "skos:exactMatch": [
          { "@id": "schema:Dataset" },
          { "@id": "dcterms:Dataset" },
          { "@id": "wd:Q1172284" },
          { "@id": "dcat:Dataset" }
  ],
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_Dissertation",
      "@type": "skos:Concept",
      "skos:prefLabel": "Dissertation",
      "skos:definition": "A written essay, treatise, or thesis, especially one written by a candidate for the degree of Doctor of Philosophy.",
      "skos:exactMatch": [
    { "@id": "schema:Thesis" },
    { "@id": "dcterms:Text" },
    { "@id": "wd:Q1266946" }
  ],
      "skos:closeMatch": { "@id": "dcterms:Text" } ,
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_Event",
      "@type": "skos:Concept",
      "skos:prefLabel": "Event",
      "skos:definition": "A non-persistent, time-based occurrence.",
      "skos:exactMatch": [
    { "@id": "schema:Event" },
    { "@id": "dcterms:Event" },
    { "@id": "wd:Q1656682" }
  ], 
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
  },
    {
      "@id": "datacite:ResourceTypeGeneral_Image",
      "@type": "skos:Concept",
      "skos:prefLabel": "Image",
      "skos:definition": "A visual representation other than text.",
      "skos:exactMatch": [
          { "@id": "schema:ImageObject" },
          { "@id": "dcterms:Image" },
          { "@id": "wd:Q478798" }
  ],
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_Instrument",
      "@type": "skos:Concept",
      "skos:prefLabel": "Instrument",
      "skos:definition": "A device, tool or apparatus used to obtain, measure and/or analyze data.",
      "skos:exactMatch": 
      [ { "@id": "schema:Instrument" },
      { "@id": "wd:Q39546" }
  ],
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_InteractiveResource",
      "@type": "skos:Concept",
      "skos:prefLabel": "InteractiveResource",
      "skos:definition": "A resource requiring interaction from the user to be understood, executed, or experienced.",
      "skos:exactMatch": { "@id": "dcterms:InteractiveResource" },
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    
    {
      "@id": "datacite:ResourceTypeGeneral_Journal",
      "@type": "skos:Concept",
      "skos:prefLabel": "Journal",
      "skos:definition": "A scholarly publication consisting of articles that is published regularly throughout the year.",
      "skos:exactMatch": [
    { "@id": "schema:Periodical" },
    { "@id": "wd:Q737498" }
  ],
      "skos:narrowMatch": { "@id": "wd:Q5633421" } ,
      "skos:closeMatch": { "@id": "dcterms:Text" },
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_JournalArticle",
      "@type": "skos:Concept",
      "skos:prefLabel": "JournalArticle",
      "skos:definition": "A written composition published in a scholarly journal, usually peer‑reviewed.",
      "skos:exactMatch": [
        { "@id": "schema:ScholarlyArticle" },
        { "@id": "wd:Q18918145" },
        { "@id": "wd:Q13442814" }
      ],
      "skos:broadMatch": [
        { "@id": "wd:Q191067" },
        { "@id": "dcterms:BibliographicResource" }
      ],
      "skos:closeMatch": { "@id": "dcterms:Text" },
      "skos:relatedMatch": { "@id": "schema:PublicationIssue" },
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
{
      "@id": "datacite:ResourceTypeGeneral_Model",
      "@type": "skos:Concept",
      "skos:prefLabel": "Model",
      "skos:definition": "An abstract, conceptual, graphical, mathematical or visualization model that represents empirical objects, phenomena, or physical processes.",
      "skos:exactMatch": [
        { "@id": "schema:3DModel" },
        { "@id": "wd:Q1979154" },
        { "@id": "wd:Q2623243" }
      ],
      "skos:narrowMatch": [
        { "@id": "wd:Q193946" },    
        { "@id": "wd:Q1122506" },   
        { "@id": "wd:Q11784425" }, 
        { "@id": "wd:Q486902" },    
        { "@id": "wd:Q3284399" },   
        { "@id": "wd:Q1172480" }  
      ],
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_OutputManagementPlan",
      "@type": "skos:Concept",
      "skos:prefLabel": "OutputManagementPlan",
      "skos:definition": "A formal document that outlines how research outputs are to be handled both during a research project and after the project is completed.",
      "skos:exactMatch": 
    { "@id": "wd:Q17085509" },
      "skos:closeMatch":{ "@id": "dcterms:Text" },
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
      "@id": "datacite:ResourceTypeGeneral_PeerReview",
      "@type": "skos:Concept",
      "skos:prefLabel": "PeerReview",
      "skos:definition": "Evaluation of scientific, academic, or professional work by others working in the same field.",
      "skos:exactMatch": [
        { "@id": "schema:Review" },
        { "@id": "wd:Q265158" }
      ],
      "skos:broadMatch": { "@id": "dcterms:BibliographicResource" },
      "skos:closeMatch": { "@id": "dcterms:Text" },
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
    {
    "@id": "datacite:ResourceTypeGeneral_PhysicalObject",
    "@type": "skos:Concept",
    "skos:prefLabel": "PhysicalObject",
    "skos:definition": "A physical object or substance.",
    "skos:exactMatch": [
    { "@id": "dcterms:PhysicalObject" },
    { "@id": "wd:Q223557" }
  ],
    "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
    "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    
},
{
      "@id": "datacite:ResourceTypeGeneral_Preprint",
      "@type": "skos:Concept",
      "skos:prefLabel": "Preprint",
      "skos:definition": "A version of a scholarly or scientific paper that precedes formal peer review and publication in a peer-reviewed scholarly or scientific journal.",
      "skos:exactMatch": { "@id": "wd:Q580922" },
      "skos:closeMatch": [
        { "@id": "dcterms:Text" },
        { "@id": "schema:Article" }
      ],
      "skos:broader": { "@id": "datacite:resourceTypeGeneral" },
      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
{
      "@id": "datacite:ResourceTypeGeneral_Project",
      "@type": "skos:Concept",
      "skos:prefLabel": "Project",
      "skos:definition": "A planned endeavor or activity, frequently collaborative, intended to achieve a particular aim using allocated resources such as budget, time, and expertise.",
