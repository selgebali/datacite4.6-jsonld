      "dcterms": "http://purl.org/dc/terms/",
      "wd": "http://www.wikidata.org/entity/"
    }
  ],
  "@graph": [
     {
      "@id": "datacite:DataCite4.6ConceptScheme",
      "@type": "skos:ConceptScheme",
      "skos:prefLabel": "DataCite Metadata Schema v4.6",
      "skos:definition": "Concept scheme for DataCite Metadata Schema version 4.6."
    },
    {
      "@id": "datacite:identifier",
      "@type": "skos:Concept",
      "skos:prefLabel": "Identifier",
      "skos:definition": "A unique string that identifies the resource.",
      "skos:exactMatch": [
        { "@id": "schema:identifier" },
        { "@id": "dcat:identifier" },
        { "@id": "dcterms:identifier" }
      ],
      "skos:closeMatch": 	
          { "@id": "wd:Q853614" },
        "skos:inScheme":
        { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
    {
      "@id": "datacite:identifierType",
      "@type": "skos:Concept",
      "skos:prefLabel": "Identifier Type",
      "skos:definition": "The scheme used for the identifier (e.g. DOI).",
      "skos:exactMatch": { "@id": "schema:PropertyValue.propertyID" },
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
    {
      "@id": "datacite:creator",
      "@type": "skos:Concept",
      "skos:prefLabel": "Creator",
      "skos:definition": "The main researchers involved in producing the data, or the authors of the publication, in priority order.",
      "skos:exactMatch": [
        { "@id": "schema:creator" },
        { "@id": "dcterms:creator" },
        { "@id": "wd:Q2500638" }
      ],
      "skos:narrowMatch": [
        { "@id": "schema:author" },
        { "@id": "wd:Q482980" }
      ],
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
     {
      "@id": "datacite:creatorName",
      "@type": "skos:Concept",
      "skos:prefLabel": "Creator Name",
      "skos:definition": "The full name of the creator.",
      "skos:exactMatch":
        { "@id": "schema:name" },
      "skos:closeMatch": { "@id": "wd:Q82799" },
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
     {
  "@id": "datacite:NameTypeScheme",
  "@type": "skos:ConceptScheme",
  "skos:prefLabel": "DataCite NameType Scheme",
  "skos:definition": "Controlled list of DataCite nameType values.",
  "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" },
  "skos:hasTopConcept": [
    { "@id": "datacite:nameType_Personal" },
    { "@id": "datacite:nameType_Organizational" }
  ]
},
{
  "@id": "datacite:nameType_Personal",
  "@type": "skos:Concept",
  "skos:prefLabel": "Personal",
  "skos:definition": "Indicates that the agent is an individual person.",
  "skos:exactMatch": [
    { "@id": "schema:Person" }
  ],
  "skos:closeMatch": [
    { "@id": "wd:Q5" }
  ],
  "skos:inScheme": { "@id": "datacite:NameTypeScheme" }
},
{
  "@id": "datacite:nameType_Organizational",
  "@type": "skos:Concept",
  "skos:prefLabel": "Organizational",
  "skos:definition": "Indicates that the agent is an organization.",
  "skos:exactMatch": [
    { "@id": "schema:Organization" }
  ],
  "skos:closeMatch": [
    { "@id": "wd:Q43229" }
  ],
  "skos:inScheme": { "@id": "datacite:NameTypeScheme" }
},
{
      "@id": "datacite:givenName",
      "@type": "skos:Concept",
      "skos:prefLabel": "Given Name",
      "skos:definition": "The personal or first name of the creator.",
      "skos:exactMatch": [
        { "@id": "schema:givenName" },
        { "@id": "wd:Q202444" }
      ],
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
 {
      "@id": "datacite:familyName",
      "@type": "skos:Concept",
      "skos:prefLabel": "Family Name",
      "skos:definition": "The surname or last name of the creator.",
      "skos:exactMatch": [
        { "@id": "schema:familyName" },
        { "@id": "wd:Q101352" }
      ],
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
    {
      "@id": "datacite:nameIdentifier",
      "@type": "skos:Concept",
      "skos:prefLabel": "Name Identifier",
      "skos:definition": "A persistent identifier for the creator (e.g. ORCID).",
      "skos:exactMatch": { "@id": "schema:identifier" },
      "skos:closeMatch": [
        { "@id": "dcat:identifier" },
        { "@id": "wd:Q853614" }
      ],
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },

{
      "@id": "datacite:nameIdentifierScheme",
      "@type": "skos:Concept",
      "skos:prefLabel": "Name Identifier Scheme",
      "skos:definition": "The scheme used for the name identifier.",
      "skos:exactMatch": { "@id": "schema:PropertyValue.propertyID" },
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
{
      "@id": "datacite:creatorSchemeURI",
      "@type": "skos:Concept",
      "skos:prefLabel": "Creator Scheme URI",
      "skos:definition": "The URI of the name identifier scheme.",
      "skos:exactMatch": { "@id": "schema:PropertyValue.propertyURL" },
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
 {
      "@id": "datacite:affiliation",
