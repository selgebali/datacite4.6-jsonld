      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },

    {
      "@id": "datacite:DateType_Accepted",
      "@type": "skos:Concept",
      "skos:prefLabel": "Accepted",
      "skos:definition": "The date that the publisher accepted the resource into their system.",
      "skos:exactMatch": { "@id": "dcterms:dateAccepted" },
      "skos:broader": { "@id": "datacite:dateType" },
      "skos:inScheme": { "@id": "datacite:DateTypeScheme" }
    },

{
      "@id": "datacite:DateType_Available",
      "@type": "skos:Concept",
      "skos:prefLabel": "Available",
      "skos:definition": "The date the resource is made publicly available.",
      "skos:exactMatch":   { "@id": "dcterms:available" },
      "skos:relatedMatch": { "@id": "schema:datePublished" },
      "skos:broader": { "@id": "datacite:dateType" },
      "skos:inScheme": { "@id": "datacite:DateTypeScheme" }
    },

{
      "@id": "datacite:DateType_Copyrighted",
      "@type": "skos:Concept",
      "skos:prefLabel": "Copyrighted",
      "skos:definition": "The specific, documented date at which the resource receives a copyrighted status, if applicable.",
      "skos:exactMatch": {"@id": "dcterms:dateCopyrighted"},
      "skos:closeMatch": {"@id": "schema:copyrightYear" },
      "skos:broader": { "@id": "datacite:dateType" },
      "skos:inScheme": { "@id": "datacite:DateTypeScheme" }
    },
{
      "@id": "datacite:DateType_Collected",
      "@type": "skos:Concept",
      "skos:prefLabel": "Collected",
      "skos:definition": " The date or date range in which the resource content was collected.",
     "skos:closeMatch":  { "@id": "dcterms:created" },          
      "skos:relatedMatch": [
    { "@id": "schema:temporalCoverage" },                 
    { "@id": "dcterms:temporal" }, 
    { "@id": "dcat:temporal" }                               
  ],
      "skos:broader": { "@id": "datacite:dateType" },
      "skos:inScheme": { "@id": "datacite:DateTypeScheme" }
    },
{
      "@id": "datacite:DateType_Coverage",
      "@type": "skos:Concept",
      "skos:prefLabel": "Coverage",
      "skos:definition": "The date or date range that the resource content applies to, describes, or covers.",
      "skos:exactMatch": [
        { "@id": "schema:temporalCoverage" },
        {"@id": "dcterms:coverage" }
    ],
      "skos:relatedMatch": {"@id":"dcterms:temporal" },
           "skos:broader": { "@id": "datacite:dateType" },
      "skos:inScheme": { "@id": "datacite:DateTypeScheme" }
    },
{
      "@id": "datacite:DateType_Created",
      "@type": "skos:Concept",
      "skos:prefLabel": "Created",
      "skos:definition": "The date the resource itself was put together; this could refer to a timeframe in ancient history, a date range, or a single date for a final component, e.g., the finalised file with all the data. ",
      "skos:exactMatch": [
        { "@id": "schema:dateCreated" },
        {"@id":"dcterms:created"} 
      ],
      "skos:broader": { "@id": "datacite:dateType" },
      "skos:inScheme": { "@id": "datacite:DateTypeScheme" }
    },
{
      "@id": "datacite:DateType_Issued",
      "@type": "skos:Concept",
      "skos:prefLabel": "Issued",
      "skos:definition": "The date that the resource is published or distributed, e.g., to a data centre.",
      "skos:exactMatch": [
        { "@id": "schema:datePublished" },
        {"@id":"dcterms:issued"}
      ], 
      "skos:broader": { "@id": "datacite:dateType" },
      "skos:inScheme": { "@id": "datacite:DateTypeScheme" }
    },
{
      "@id": "datacite:DateType_Submitted",
      "@type": "skos:Concept",
      "skos:prefLabel": "Submitted",
      "skos:definition": "The date the creator submits the resource to the publisher.",
      "skos:exactMatch": { "@id": "dcterms:dateSubmitted" }, 
      "skos:broader": { "@id": "datacite:dateType" },
      "skos:inScheme": { "@id": "datacite:DateTypeScheme" }
    },
{
      "@id": "datacite:DateType_Updated",
      "@type": "skos:Concept",
      "skos:prefLabel": "Updated",
      "skos:definition": "The date of the last update to the resource, when the resource is being added to. May be a range.",
      "skos:exactMatch": [
        { "@id": "schema:dateModified" },
        {"@id": "dcterms:modified"}
      ],
      "skos:broader": { "@id": "datacite:dateType" },
      "skos:inScheme": { "@id": "datacite:DateTypeScheme" }
    },

{
      "@id": "datacite:DateType_Valid",
      "@type": "skos:Concept",
      "skos:prefLabel": "Valid",
      "skos:definition": "The date or date range during which the dataset or resource is accurate.",
      "skos:exactMatch": [ 
        { "@id": "schema:validFrom" },
        {"@id": "dcterms:valid"}
],
      "skos:broader": { "@id": "datacite:dateType" },
      "skos:inScheme": { "@id": "datacite:DateTypeScheme" }
    },

    {
      "@id": "datacite:DateType_Withdrawn",
      "@type": "skos:Concept",
      "skos:prefLabel": "Withdrawn",
      "skos:definition": "The date the resource was withdrawn or deleted.",
      "skos:relatedMatch": { "@id": "schema:dateDeleted" },
      "skos:broader": { "@id": "datacite:dateType" },
      "skos:inScheme": { "@id": "datacite:DateTypeScheme" }
    },
{
      "@id": "datacite:DateType_Other",
      "@type": "skos:Concept",
      "skos:prefLabel": "Other",
      "skos:definition": "Any other date type not covered.",
      "skos:closeMatch": { "@id": "schema:additionalType" },
      "skos:broader": { "@id": "datacite:dateType" },
      "skos:inScheme": { "@id": "datacite:DateTypeScheme" }
    },
{
      "@id": "datacite:dateInformation",
      "@type": "skos:Concept",
      "skos:prefLabel": "Date Information",
      "skos:definition": "Free-text details about the date (e.g. \"55 BC\").",
      "skos:exactMatch": { "@id": "schema:description" },
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" }
    },
    {
  "@id": "datacite:Language",
  "@type": "skos:Concept",
  "skos:prefLabel": "Language",
  "skos:definition": "The language the resource is in.",
  "skos:exactMatch":   [
    { "@id": "schema:inLanguage" },
    {"@id": "dcterms:language"}
  ],
  "skos:inScheme":{ "@id": "datacite:DataCite4.6ConceptScheme" }
},
    {
      "@id": "datacite:ResourceTypeGeneralScheme",
      "@type": "skos:ConceptScheme",
      "skos:prefLabel": "DataCite ResourceTypeGeneral Scheme",
      "skos:definition": "Controlled list of DataCite resourceTypeGeneral values.",
      "skos:inScheme": { "@id": "datacite:DataCite4.6ConceptScheme" },
