      "skos:inScheme": { "@id": "datacite:ResourceTypeGeneralScheme" }
    },
{
      "@id": "datacite:ResourceTypeGeneral_Report",
      "@type": "skos:Concept",
      "skos:prefLabel": "Report",
      "skos:definition": " A document that presents information in an organized format for a specific audience and purpose.",
