      "firstPage": { "@id": "Property:firstPage" },
      "lastPage": { "@id": "Property:lastPage" },
      "edition": { "@id": "Property:edition" },
      "relatedItemContributor": { "@id": "Property:contributor" },
      "relatedItemContributorType": { "@id": "Property:contributorType" },
      "relatedItemContributorName": { "@id": "Property:contributorName" },
      "relatedItemContributorNameType": { "@id": "Property:nameType" },
      "relatedItemContributorGivenName": { "@id": "Property:givenName" },
      "relatedItemContributorFamilyName": { "@id": "Property:familyName" },

      "$comment": "Validation examples: After applying this @context, JSON properties expand to semantic IRIs. Example: {'doi': '10.1234/example'} becomes {'https://schema.datacite.org#identifier': [{'@value': '10.1234/example', '@type': 'http://www.w3.org/2001/XMLSchema#string'}]}. Complex objects like 'publisher' use nested contexts for sub-properties."
    }
  },
