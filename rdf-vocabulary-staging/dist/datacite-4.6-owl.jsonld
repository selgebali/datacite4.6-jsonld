      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Subtitle",
      "notation": "Subtitle",
      "definition": "A secondary title that follows the main title and provides additional information about the resource.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/titleType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/titleType",
