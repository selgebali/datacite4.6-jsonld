    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/CrossrefFunderID",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Crossref Funder ID",
      "altLabel": "Crossref Funder Registry ID",
      "notation": "Crossref Funder ID",
      "definition": "A persistent identifier for a funding body assigned by the Crossref Funder Registry, a curated, openly licensed registry of funder names and identifiers used to disambiguate funding organizations in scholarly metadata.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/CrossrefFunderID.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/GRID",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "GRID",
      "altLabel": "Global Research Identifier Database",
      "notation": "GRID",
      "definition": "A persistent identifier for a research organization issued by the Global Research Identifier Database (GRID), a free database of research-related institution identifiers maintained by Digital Science.",
      "scopeNote": "GRID identifiers were succeeded by ROR identifiers in 2021; new records SHOULD prefer ROR where an equivalent ROR identifier exists.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/GRID.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/ISNI",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "ISNI",
      "altLabel": "International Standard Name Identifier",
      "notation": "ISNI",
      "definition": "A 16-character identifier for the public identity of a person or organization, defined by ISO 27729 and assigned by the ISNI International Agency. When used as a funder identifier, the ISNI uniquely identifies the funding organization.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/ISNI.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/Other",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Other",
      "notation": "Other",
      "definition": "Any funder identifier type not covered by the other values in the funderIdentifierType controlled list.",
      "scopeNote": "Use Other for funder identifier schemes that are not represented by a named value in this vocabulary. If a particular scheme is in common use, consider proposing it as a named value in a future DataCite release.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/Other.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/ROR",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "ROR",
      "altLabel": "Research Organization Registry",
      "notation": "ROR",
      "definition": "A persistent identifier for a research organization from the Research Organization Registry (ROR), a community-led, open registry of unique identifiers for every organization that performs, funds, or otherwise contributes to research.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/ROR.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/identifierType",
      "type": [
        "owl:NamedIndividual",
        "ConceptScheme"
      ],
