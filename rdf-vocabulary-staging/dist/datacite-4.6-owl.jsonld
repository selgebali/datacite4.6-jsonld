      "example": [
        "<relatedIdentifier relatedIdentifierType=\"DOI\" relationType=\"IsCollectedBy\">10.5072/instrument</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCollectedBy.jsonld"
      ]
    },
