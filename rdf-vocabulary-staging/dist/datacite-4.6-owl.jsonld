      "example": [
        "<relatedIdentifier relatedIdentifierType=\"DOI\" relationType=\"IsCitedBy\">10.4232/10.ASEAS-5.2-1</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCitedBy.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCollectedBy",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "IsCollectedBy",
      "notation": "IsCollectedBy",
