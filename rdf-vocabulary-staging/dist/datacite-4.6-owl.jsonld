      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Service",
      "notation": "Service",
      "definition": "An organized system of apparatus, appliances, staff, etc., for supplying some function(s) required by end users.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
      "scopeNote": "Data management service, or long-term preservation service",
      "example": [
        "https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.21938/3I01ISNUCODNH1ZJBCVUWA"
      ],
