      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Preprint",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Preprint",
      "notation": "Preprint",
      "definition": "A version of a scholarly or scientific paper that precedes formal peer review and publication in a peer-reviewed scholarly or scientific journal.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
