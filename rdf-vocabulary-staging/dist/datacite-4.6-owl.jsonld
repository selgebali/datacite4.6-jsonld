      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Standard",
      "notation": "Standard",
      "definition": "Something established by authority, custom, or general consent as a model, example, or point of reference.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
