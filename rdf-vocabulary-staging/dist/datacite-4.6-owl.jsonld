      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "IsIdenticalTo",
      "notation": "IsIdenticalTo",
      "definition": "indicates that A is identical to B, for use when there is a need to register two separate instances of the same resource",
