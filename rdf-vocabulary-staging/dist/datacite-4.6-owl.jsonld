      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ARK",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "ARK",
      "altLabel": "Archival Resource Key",
      "notation": "ARK",
      "definition": "A URI designed to support long-term access to information objects. In general, ARK syntax is of the form (brackets, []. indicate optional elements): [http://NMA/]ark:/NAAN/Name [Qualifier].",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"ARK\" relationType=\"IsCitedBy\">ark:/13030/tqb3kh97gh8w</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ARK.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/arXiv",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "arXiv",
      "altLabel": "arXiv identifier",
      "notation": "arXiv",
      "definition": "arXiv.org is a repository of preprints of scientific papers in the fields of mathematics, physics, astronomy, computer science, quantitative biology, statistics, and quantitative finance.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"arXiv\" relationType=\"IsCitedBy\">arXiv:0706.0001</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/arXiv.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/bibcode",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "bibcode",
      "altLabel": "Astrophysics Data System bibliographic codes",
      "notation": "bibcode",
      "definition": "A standardized 19-character identifier according to the syntax yyyyjjjjjvvvvmppppa. See http://info-uri.info/registry/OAIHandler?verb=GetRecord&metadataPrefix=reg&identifier=info:bibcode/. Note: bibcodes can be searched via https://ui.adsabs.harvard.edu/ or resolved using https://ui.adsabs.harvard.edu/abs/<bibcode>.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"bibcode\" relationType=\"IsCitedBy\">2018AGUFM.A24K..07S</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/bibcode.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/CSTR",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "CSTR",
      "altLabel": "Common Science and Technology Resources Identifier",
      "notation": "CSTR",
      "definition": "CSTR is an identifier based on the Chinese National Standard GB/T 32843—2016 “Science and technology resource identification”, providing a unique identification service for scientific data, papers, scientific institutions, researchers, scientific instruments, patents and other scientific and technological resources.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"CSTR\" relationType=\"References\">31253.11.sciencedb.13238</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/CSTR.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/DOI",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "DOI",
      "altLabel": "Digital Object Identifier",
      "notation": "DOI",
      "definition": "A character string used to uniquely identify an object. A DOI name is divided into two parts, a prefix and a suffix, separated by a slash.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"DOI\" relationType=\"IsSupplementTo\">10.1016/j.epsl.2011.11.037</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/DOI.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/EAN13",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "EAN13",
      "altLabel": "European Article Number (now renamed International Article Number, but retaining the original acronym)",
      "notation": "EAN13",
      "definition": "A 13-digit barcoding standard that is a superset of the original 12-digit Universal Product Code (UPC) system.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"EAN13\" relationType=\"Cites\">9783468111242</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/EAN13.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/EISSN",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "EISSN",
      "altLabel": "Electronic International Standard Serial Number",
      "notation": "EISSN",
      "definition": "ISSN used to identify periodicals in electronic form (eISSN or e-ISSN).",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"eISSN\" relationType=\"Cites\">1562-6865</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/EISSN.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/Handle",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Handle",
      "altLabel": "Handle",
      "notation": "Handle",
      "definition": "This refers specifically to an ID in the Handle system operated by the Corporation for National Research Initiatives (CNRI).",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"Handle\" relationType=\"References\">10013/epic.10033</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/Handle.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/IGSN",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "IGSN",
      "altLabel": "International Generic Sample Number",
      "notation": "IGSN",
      "definition": "A code that uniquely identifies samples from our natural environment and related features-of-interest.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"IGSN\" relationType=\"References\">IECUR0097</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/IGSN.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISBN",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "ISBN",
      "altLabel": "International Standard Book Number",
      "notation": "ISBN",
      "definition": "A unique numeric book identifier. There are 2 formats: a 10-digit ISBN format and a 13-digit ISBN.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"ISBN\" relationType=\"IsPartOf\">978-3-905673-82-1</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISBN.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISSN",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "ISSN",
      "altLabel": "International Standard Serial Number",
      "notation": "ISSN",
      "definition": "A unique 8-digit number used to identify a print or electronic periodical publication.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"ISSN\" relationType=\"IsPartOf\">0077-5606</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISSN.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISTC",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "ISTC",
      "altLabel": "International Standard Text Code",
      "notation": "ISTC",
      "definition": "A unique “number” assigned to a textual work. An ISTC consists of 16 numbers and/or letters.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"ISTC\" relationType=\"Cites\">0A9 2002 12B4A105 7</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISTC.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/LISSN",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "LISSN",
      "altLabel": "Linking ISSN",
      "notation": "LISSN",
      "definition": "The linking ISSN or ISSN-L enables collocation or linking among different media versions of a continuing resource.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"LISSN\" relationType=\"Cites\">1188-1534</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/LISSN.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/LSID",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "LSID",
      "altLabel": "Life Science Identifiers",
      "notation": "LSID",
      "definition": "A unique identifier for data in the Life Science domain. Format: urn:lsid:authority:namespace:identifier:revision.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"LSID\" relationType=\"Cites\">urn:lsid:ubio.org:namebank:11815</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/LSID.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/PMID",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "PMID",
      "altLabel": "PubMed identifier",
      "notation": "PMID",
      "definition": "A unique number assigned to each PubMed record.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"PMID\" relationType=\"IsReferencedBy\">12082125</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/PMID.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/PURL",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "PURL",
      "altLabel": "Persistent Uniform Resource Locator",
      "notation": "PURL",
      "definition": "A PURL has three parts: (1) a protocol, (2) a resolver address, and (3) a name.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"PURL\" relationType=\"Cites\">http://purl.oclc.org/foo/bar</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/PURL.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/RRID",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "RRID",
      "altLabel": "Research Resource IDentifier",
      "notation": "RRID",
      "definition": "A character string used to uniquely identify key inputs to an experiment including the so-called “key biological resources” as defined by the National Institutes of Health, and related tools such as core facilities and databases. An RRID name is divided into two parts, the authority and a local identifier, separated by an underscore.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"RRID\" relationType=\"Cites\">RRID:SCR_014641</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/RRID.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/UPC",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "UPC",
      "altLabel": "Universal Product Code",
      "notation": "UPC",
      "definition": "A barcode symbology used for tracking trade items in stores. Its most common form, the UPC-A, consists of 12 numerical digits.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"UPC\" relationType=\"Cites\">123456789999</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/UPC.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/URL",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "URL",
      "altLabel": "Uniform Resource Locator",
      "notation": "URL",
      "definition": "Also known as web address, a URL is a specific character string that constitutes a reference to a resource. The syntax is: scheme://domain:port/path?query_string#fragment_id.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"URL\" relationType=\"IsCitedBy\">http://www.heatflow.und.edu/index2.html</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/URL.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/URN",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "URN",
      "altLabel": "Uniform Resource Name",
      "notation": "URN",
      "definition": "A unique and persistent identifier of an electronic document. The syntax is: urn:<NID>:<NSS>. The leading urn: sequence is case-insensitive, <NID> is the namespace identifier, <NSS> is the namespace-specific string.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"URN\" relationType=\"IsSupplementTo\">urn:nbn:de:101:1-201102033592</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/URN.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/w3id",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "w3id",
      "altLabel": "Permanent identifier for Web applications",
      "notation": "w3id",
      "definition": "Mostly used to publish vocabularies and ontologies. The letters ‘w3’ stand for “World Wide Web”.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"w3id\" relationType=\"IsCitedBy\">https://w3id.org/games/spec/coil#Coil_Bomb_Die_Of_Age</relatedIdentifier>"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/w3id.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "type": [
        "owl:NamedIndividual",
        "ConceptScheme"
      ],
      "title": "DataCite 4.6 relationType",
      "identifier": "relationType",
