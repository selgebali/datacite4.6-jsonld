        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Withdrawn",
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Other"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/dateType.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType/Accepted",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Accepted",
      "notation": "Accepted",
      "definition": "The date that the publisher accepted the resource into their system.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "scopeNote": "To indicate the start of an embargo period, use Accepted or Submitted, as appropriate.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Accepted.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType/Available",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Available",
      "notation": "Available",
      "definition": "The date the resource is made publicly available. May be a range.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "scopeNote": "To indicate the end of an embargo period, use Available.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Available.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType/Collected",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Collected",
      "notation": "Collected",
      "definition": "The date or date range in which the resource content was collected.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "scopeNote": "To indicate precise or particular timeframes in which research was conducted.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Collected.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType/Copyrighted",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Copyrighted",
      "notation": "Copyrighted",
      "definition": "The specific, documented date at which the resource receives a copyrighted status, if applicable.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Copyrighted.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType/Coverage",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Coverage",
      "notation": "Coverage",
      "definition": "The date or date range that the resource content applies to, describes, or covers.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "scopeNote": "To indicate the temporal coverage of the resource, use Coverage. This may be different from Collected.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Coverage.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType/Created",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Created",
      "notation": "Created",
      "definition": "The date the resource itself was put together; this could refer to a timeframe in ancient history, a date range, or a single date for a final component, e.g., the finalised file with all the data.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "scopeNote": "Recommended for discovery.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Created.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType/Issued",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Issued",
      "notation": "Issued",
      "definition": "The date that the resource is published or distributed, e.g., to a data centre.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Issued.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType/Other",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Other",
      "notation": "Other",
      "definition": "Other date that does not fit into an existing category.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Other.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType/Submitted",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Submitted",
      "notation": "Submitted",
      "definition": "The date the creator submits the resource to the publisher. This could be different from Accepted if the publisher then applies a selection process.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "scopeNote": "Recommended for discovery. To indicate the start of an embargo period, use Submitted or Accepted, as appropriate.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Submitted.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType/Updated",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Updated",
      "notation": "Updated",
      "definition": "The date of the last update to the resource, when the resource is being added to. May be a range.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Updated.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType/Valid",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Valid",
      "notation": "Valid",
      "definition": "The date or date range during which the dataset or resource is accurate.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Valid.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType/Withdrawn",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Withdrawn",
      "notation": "Withdrawn",
      "definition": "The date the resource is removed.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "scopeNote": "It is good practice to include a Description that indicates the reason for the retraction or withdrawal.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/dateType/Withdrawn.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/descriptionType",
      "type": [
        "owl:NamedIndividual",
        "ConceptScheme"
      ],
      "title": "DataCite 4.6 descriptionType",
      "identifier": "descriptionType",
      "created": "2026-02-20",
      "hasTopConcept": [
        "https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Abstract",
        "https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Methods",
        "https://schema.stage.datacite.org/linked-data/vocab/descriptionType/SeriesInformation",
        "https://schema.stage.datacite.org/linked-data/vocab/descriptionType/TableOfContents",
        "https://schema.stage.datacite.org/linked-data/vocab/descriptionType/TechnicalInfo",
        "https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Other"
      ],
