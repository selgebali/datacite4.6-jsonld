      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/ContactPerson",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "ContactPerson",
      "notation": "ContactPerson",
      "definition": "Person with knowledge of how to access, troubleshoot, or otherwise field issues related to the resource.",
      "scopeNote": "May also be the “Point of Contact” in an organisation that controls access to the resource, if that organisation is different from the Publisher, Distributor, and Data Manager.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/ContactPerson.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataCollector",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "DataCollector",
      "notation": "DataCollector",
      "definition": "Person/institution responsible for finding or gathering/collecting data under the guidelines of the author(s) or Principal Investigator (PI).",
      "scopeNote": "May also be used when crediting survey conductors, interviewers, event or condition observers, or persons responsible for monitoring key instrument data.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataCollector.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataCurator",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "DataCurator",
      "notation": "DataCurator",
      "definition": "Person tasked with reviewing, enhancing, cleaning, or standardizing metadata and the associated data submitted for storage, use, and maintenance within a data centre or repository.",
      "scopeNote": "While the DataManager is concerned with digital maintenance, the DataCurator’s role encompasses quality assurance focused on content and metadata. Responsibilities can include checking completeness; verifying standard metadata; adding/verifying specialized metadata; and determining how metadata maps to search engines, database products, and automated feeds. Repository managers and data librarians may fall within this category.",
      "example": [
        "https://doi.org/10.20375/0000-000D-1D1F-2"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataCurator.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataManager",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "DataManager",
      "notation": "DataManager",
      "definition": "Person (or organisation with a staff of data managers, such as a data centre) responsible for maintaining the finished resource.",
      "scopeNote": "Ensures the resource is periodically refreshed (software/hardware support), kept available/protected from unauthorized access, stored according to industry standards, and handled according to applicable records management requirements.",
      "example": [
        "https://doi.org/10.6073/pasta/41b3ed2e152e1e4c3846e646118208e7"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataManager.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Distributor",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Distributor",
      "notation": "Distributor",
      "definition": "Institution tasked with responsibility to generate/disseminate copies of the resource in either electronic or print form.",
      "scopeNote": "Works stored in more than one archive/repository may credit each as a distributor.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Distributor.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Editor",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Editor",
      "notation": "Editor",
      "definition": "A person who oversees the details related to the publication format of the resource.",
      "scopeNote": "If the Editor is to be credited in place of multiple creators, the Editor’s name may be supplied as Creator, with “(Ed.)” appended to the name.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Editor.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/HostingInstitution",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "HostingInstitution",
      "notation": "HostingInstitution",
      "definition": "Typically, the organisation allowing the resource to be available on the internet through the provision of its hardware/software/operating support.",
      "scopeNote": "This role normally falls on the university, research center, or organization where the data center/repository belongs. May also be used for an organisation that stores the data offline, often a data centre if that data centre is not the publisher.",
      "example": [
        "Université Grenoble Alpes (UGA)"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/HostingInstitution.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Other",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Other",
      "notation": "Other",
      "definition": "Any person or institution making a significant contribution to the development and/or maintenance of the resource, but whose contribution is not adequately described by any of the other values for contributorType.",
      "scopeNote": "Could be a photographer, artist, or writer whose contribution helped to publicize the resource (as opposed to creating it), a reviewer, someone providing administrative services (depositing updates, analysing usage), etc.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Other.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Producer",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Producer",
      "notation": "Producer",
      "definition": "Typically, a person or organisation responsible for the artistry and form of a media product.",
      "scopeNote": "In the data industry, this may be a company producing DVDs that package data for future dissemination by a distributor.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Producer.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectLeader",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "ProjectLeader",
      "notation": "ProjectLeader",
      "definition": "Person officially designated as head of project team or sub-project team instrumental in the work necessary to development of the resource.",
      "scopeNote": "The Project Leader remains intimately involved throughout the life of the particular project team.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectLeader.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectManager",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "ProjectManager",
      "notation": "ProjectManager",
      "definition": "Person officially designated as manager of a project. Project may consist of one or many project teams and sub-teams.",
      "scopeNote": "The manager of a project normally has more administrative responsibility than actual work involvement.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectManager.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectMember",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "ProjectMember",
      "notation": "ProjectMember",
      "definition": "Person on the membership list of a designated project/project team.",
      "scopeNote": "This vocabulary may or may not indicate the quality, quantity, or substance of the person’s involvement.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectMember.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/RegistrationAgency",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "RegistrationAgency",
      "notation": "RegistrationAgency",
      "definition": "Institution/organisation officially appointed by a Registration Authority to handle specific tasks within a defined area of responsibility.",
      "scopeNote": "DataCite is a Registration Agency for the International DOI Foundation (IDF). One task is to assign DOI prefixes to allocating agents who then assign full DOI strings to clients and provide metadata back to the DataCite registry.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/RegistrationAgency.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/RegistrationAuthority",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "RegistrationAuthority",
      "notation": "RegistrationAuthority",
      "definition": "A standards-setting body from which Registration Agencies obtain official recognition and guidance.",
      "scopeNote": "The IDF serves as the Registration Authority for the International Standards Organisation (ISO) in the area/domain of Digital Object Identifiers.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/RegistrationAuthority.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/RelatedPerson",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "RelatedPerson",
      "notation": "RelatedPerson",
      "definition": "A person without a specifically defined role in the development of the resource, but who is someone the author wishes to recognize.",
      "scopeNote": "Could be an author’s intellectual mentor, a person providing intellectual leadership in the discipline or subject domain, etc.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/RelatedPerson.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Researcher",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Researcher",
      "notation": "Researcher",
      "definition": "A person involved in analysing data or the results of an experiment or formal study.",
      "scopeNote": "Should be a person, not an institution. A person gathering data would typically be DataCollector. A researcher may find additional data online and correlate it to collected data.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Researcher.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/ResearchGroup",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "ResearchGroup",
      "notation": "ResearchGroup",
      "definition": "Typically refers to a group of individuals with a lab, department, or division that has a specifically defined focus of activity.",
      "scopeNote": "May operate at a narrower level of scope; may or may not hold less administrative responsibility than a project team.",
      "example": [
        "Space Research & Planetary Sciences Division of the University of Bern (WP Unibe)",
        "doi:10.26302/SSHADE/EXPERIMEN T_OP_20201104_001"
      ],
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/ResearchGroup.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/RightsHolder",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "RightsHolder",
      "notation": "RightsHolder",
      "definition": "Person or institution owning or managing property rights, including intellectual property rights over the resource.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/RightsHolder.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Sponsor",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Sponsor",
      "notation": "Sponsor",
      "definition": "Person or organisation that issued a contract or under the auspices of which a work has been written, printed, published, developed, etc.",
      "scopeNote": "Includes organisations that provide in-kind support (donation, people, facility, instrumentation) necessary for development of the resource.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Sponsor.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Supervisor",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Supervisor",
      "notation": "Supervisor",
      "definition": "Designated administrator over one or more groups/teams working to produce a resource, or over one or more steps of a development process.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Supervisor.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Translator",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Translator",
      "notation": "Translator",
      "definition": "A person, organization, or automated system responsible for converting the content of a resource from one language into another, preserving its meaning and intended message.",
      "scopeNote": "Apply to DOI metadata for a resource which has been translated from another resource.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/Translator.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/contributorType/WorkPackageLeader",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "WorkPackageLeader",
      "notation": "WorkPackageLeader",
      "definition": "A Work Package is a recognized data product, not all of which is included in publication. The package may include notes, discarded documents, etc. The Work Package Leader is responsible for ensuring comprehensive contents, versioning, and availability of the Work Package during development of the resource.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/contributorType",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/contributorType/WorkPackageLeader.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/dateType",
      "type": [
        "owl:NamedIndividual",
        "ConceptScheme"
      ],
      "title": "DataCite 4.6 dateType",
      "identifier": "dateType",
      "created": "2026-02-20",
      "hasTopConcept": [
