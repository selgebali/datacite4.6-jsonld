      "example": [
        "<relatedIdentifier relatedIdentifierType=\"URL\" relationType=\"IsCompiledBy\">http://d-nb.info/gnd/4513749-3</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCompiledBy.jsonld"
      ]
    },
