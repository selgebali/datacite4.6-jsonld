        "https://schema.stage.datacite.org/linked-data/vocab/relationType/Compiles",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsVariantFormOf",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsOriginalFormOf",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsIdenticalTo",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsReviewedBy",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/Reviews",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDerivedFrom",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSourceOf",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsRequiredBy",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/Requires",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/Obsoletes",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsObsoletedBy",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCollectedBy",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/Collects",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsTranslationOf",
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/HasTranslation"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/relationType.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType/Cites",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Cites",
      "notation": "Cites",
      "definition": "indicates that A includes B in a citation",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "scopeNote": "Recommended for discovery.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"ISBN\" relationType=\"Cites\">0761964312</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/Cites.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType/Collects",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Collects",
      "notation": "Collects",
      "definition": "Indicates A collects B",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "scopeNote": "May indicate relationship between an instrument and a dataset it collected/observed.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"DOI\" relationType=\"Collects\">10.5072/data</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/Collects.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType/Compiles",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Compiles",
      "notation": "Compiles",
      "definition": "indicates B is the result of a compile or creation event using A",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "scopeNote": "May be used for software and text; a compiler can be a computer program or a person.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"URN\" relationType=\"Compiles\">urn:nbn:de:bsz:21-opus-963</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/Compiles.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType/Continues",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Continues",
      "notation": "Continues",
      "definition": "indicates A is a continuation of the work B",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"URN\" relationType=\"Continues\">urn:nbn:de:bsz:21-opus-4966</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/Continues.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType/Describes",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Describes",
      "notation": "Describes",
      "definition": "indicates A describes B",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"DOI\" relationType=\"Describes\">10.6084/m9.figshare.c.3288407</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/Describes.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType/Documents",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Documents",
      "notation": "Documents",
      "definition": "indicates A is documentation about/explaining B",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "scopeNote": "May be used for software documentation.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"DOI\" relationType=\"Documents\">10.1234/7836</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/Documents.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType/HasMetadata",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "HasMetadata",
      "notation": "HasMetadata",
      "definition": "indicates resource A has additional metadata B",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"DOI\" relationType=\"HasMetadata\" relatedMetadataScheme=\"DDI-L\" schemeURI=\"http://www.ddialliance.org/Specification/DDI-Lifecycle/3.1/XMLSchema/instance.xsd\">10.1234/567890</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/HasMetadata.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType/HasPart",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "HasPart",
      "notation": "HasPart",
      "definition": "indicates A includes the part B",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "scopeNote": "Recommended for discovery. Primarily applied to container-contained relationships. May be used for individual software modules; code repository-to-version should use IsVersionOf/HasVersion.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"URL\" relationType=\"HasPart\">https://zenodo.org/record/16564/files/dune-stuff-LSSC_15.zip</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/HasPart.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType/HasTranslation",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "HasTranslation",
      "notation": "HasTranslation",
      "definition": "indicates A has a translation B",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "scopeNote": "When a resource is shared in one language and later translated, use HasTranslation to link original to translation. If released simultaneously in multiple languages, connect in both directions.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"DOI\" relationType=\"HasTranslation\">10.21384/g01j-jm06</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/HasTranslation.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType/HasVersion",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "HasVersion",
      "notation": "HasVersion",
      "definition": "indicates A has a version B",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "scopeNote": "The registered resource such as a software package or code repository has a versioned instance (A has instance B). May relate an un-versioned code repository to a specific software version.",
      "example": [
        "<relatedIdentifier relatedIdentifierType=\"DOI\" relationType=\"HasVersion\">10.5281/ZENODO.832053</relatedIdentifier>"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/relationType/HasVersion.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCitedBy",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "IsCitedBy",
      "notation": "IsCitedBy",
      "definition": "indicates that B includes A in a citation",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/relationType",
