    {
      "id": "https://schema.stage.datacite.org/linked-data/dist/datacite-4.6",
      "type": "owl:Ontology",
      "title": "DataCite Linked Data 4.6 Distribution",
      "identifier": "datacite-4.6",
      "versionInfo": "4.6",
      "created": "2026-05-13",
      "license": "https://www.apache.org/licenses/LICENSE-2.0",
      "source": "https://schema.stage.datacite.org/linked-data/manifest/datacite-4.6.json",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/dist/datacite-4.6.jsonld",
        "https://schema.stage.datacite.org/linked-data/dist/datacite-4.6.ttl",
        "https://schema.stage.datacite.org/linked-data/dist/datacite-4.6.rdf"
      ],
      "comment": "Integrated distribution of the DataCite linked-data classes, properties, vocabulary schemes, and vocabulary terms for schema version 4.6."
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/AlternateIdentifier",
      "type": "owl:Class",
      "label": "AlternateIdentifier",
      "comment": "An identifier other than the primary Identifier applied to the resource being registered. This may be any alphanumeric string which is unique within its domain of issue. May be used for local identifiers, a serial number of an instrument or an inventory number. The AlternateIdentifier should be an additional identifier for the same instance of the resource (i.e., same location, same file).",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/AlternateIdentifier.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Contributor",
      "type": "owl:Class",
      "label": "Contributor",
      "comment": " The institution or person responsible for collecting, managing, distributing, or otherwise contributing to the development of the resource. To supply multiple contributors, repeat this property. For software, if there is an alternate entity that “holds, archives, publishes, prints, distributes, releases, issues, or produces” the code, use the contributorType “HostingInstitution” for the code repository. For instruments, if there is an institution responsible for the management of the instrument (for example, the legal owner, the operator, or an institute providing access to the instrument), use the contributorType “HostingInstitution” for the owner of the instrument.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Contributor.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Creator",
      "type": "owl:Class",
      "label": "Creator",
      "comment": "The main researchers involved in producing the data, or the authors of the publication, in priority order. For instruments this is the manufacturer or developer of the instrument. To supply multiple creators, repeat this property.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Creator.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Date",
      "type": "owl:Class",
      "label": "Date",
      "comment": "Different dates relevant to the work.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Date.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Description",
      "type": "owl:Class",
      "label": "Description",
      "comment": " All additional information that does not fit in any of the other categories. May be used for technical information or detailed information associated with a scientific instrument.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Description.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Format",
      "type": "owl:Class",
      "label": "Format",
      "comment": "Technical format of the resource.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Format.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/FundingReference",
      "type": "owl:Class",
      "label": "FundingReference",
      "comment": "Information about financial support (funding) for the resource being registered.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/FundingReference.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/GeoLocation",
      "type": "owl:Class",
      "label": "GeoLocation",
      "comment": "Spatial region or named place where the data was gathered or about which the data is focused.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/GeoLocation.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Identifier",
      "type": "owl:Class",
      "label": "Identifier",
      "comment": "The Identifier is a unique string that identifies a resource.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Identifier.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Language",
      "type": "owl:Class",
      "label": "Language",
      "comment": "The primary language of the resource.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Language.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/PublicationYear",
      "type": "owl:Class",
      "label": "PublicationYear",
      "comment": "The year when the data was or will be made publicly available. In the case of resources such as software or dynamic data where there may be multiple releases in one year, include the Date property and sub-properties (dateType/dateInformation) to provide more information about the publication or release date details.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/PublicationYear.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Publisher",
      "type": "owl:Class",
      "label": "Publisher",
      "comment": "The name of the entity that holds, archives, publishes, prints, distributes, releases, issues, or produces the resource. This property will be used to formulate the citation, so consider the prominence of the role.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Publisher.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/RelatedIdentifier",
      "type": "owl:Class",
      "label": "RelatedIdentifier",
      "comment": "Identifiers of related resources. These must be globally unique identifiers.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/RelatedIdentifier.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/RelatedItem",
      "type": "owl:Class",
      "label": "RelatedItem",
      "comment": "Information about a resource related to the one being registered.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/RelatedItem.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Resource",
      "type": "owl:Class",
      "label": "Resource",
      "comment": "Any object (data, software, instrument, document, sample, etc.) that can be cited via a DataCite-assigned persistent identifier (DOI). This is the root class of the DataCite Metadata Schema; every DataCite record describes exactly one Resource.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Resource.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/ResourceType",
      "type": "owl:Class",
      "label": "ResourceType",
      "comment": "A description of the resource.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/ResourceType.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Rights",
      "type": "owl:Class",
      "label": "Rights",
      "comment": "Any rights information for this resource.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Rights.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Size",
      "type": "owl:Class",
      "label": "Size",
      "comment": "Size (e.g., bytes, pages, inches, etc.) or duration (extent), e.g., hours, minutes, days, etc., of a resource.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Size.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Subject",
      "type": "owl:Class",
      "label": "Subject",
      "comment": "Subject, keyword, classification code, or key phrase describing the resource.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Subject.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Title",
      "type": "owl:Class",
      "label": "Title",
      "comment": "A name or title by which a resource is known. May be the title of a dataset or the name of a piece of software or an instrument.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Title.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/class/Version",
      "type": "owl:Class",
      "label": "Version",
      "comment": "The version number of the resource.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/class/Version.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/property/affiliation",
      "type": "owl:ObjectProperty",
      "label": "affiliation",
      "comment": "The organizational or institutional affiliation of the creator.",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/property/affiliation.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/property/affiliationIdentifier",
      "type": "owl:ObjectProperty",
      "label": "affiliationIdentifier",
      "comment": "Uniquely identifies the organizational affiliation of the creator.",
