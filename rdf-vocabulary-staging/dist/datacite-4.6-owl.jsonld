    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/StudyRegistration",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "StudyRegistration",
      "notation": "StudyRegistration",
      "definition": "A detailed, time-stamped description of a research plan, often openly shared in a registry or published in a journal before the study is conducted to lend accountability and transparency in the hypothesis generating and testing process.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
      "scopeNote": "Includes pre-registrations, registered reports, and clinical trials. Study registrations are sometimes peer-reviewed and may include the hypothesis, expected results, study design, and/or analysis plan.\n<resourceType resourceTypeGeneral=\"StudyRegistration\">Pre-registration</resourceType>",
      "closeMatch": [
        "https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/StudyRegistration.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Text",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Text",
      "notation": "Text",
      "definition": "A resource consisting primarily of words for reading that is not covered by any other textual resource type in this list.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
      "example": [
        "https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.5682/9786065914018"
      ],
      "closeMatch": [
        "https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Text.jsonld"
      ]
    },
    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Workflow",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Workflow",
      "notation": "Workflow",
      "definition": "A structured series of steps which can be executed to produce a final outcome, allowing users a means to specify and enact their work in a more reproducible manner.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
      "scopeNote": "Computational workflows involving sequential operations made on data by wrapped software and may be specified in a format belonging to a workflow management system, such as Taverna (http://www.taverna.org.uk/).",
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Workflow.jsonld"
      ]
    },
