    {
      "id": "https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Abstract",
      "type": [
        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "Abstract",
      "notation": "Abstract",
      "definition": "A brief description of the resource and the context in which the resource was created.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/descriptionType",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/descriptionType",
      "scopeNote": "Recommended for discovery. Use “<br>” to indicate a line break for improved rendering of multiple paragraphs, but otherwise no html markup.",
      "example": [
        "https://data.datacite.org/application/vnd.datacite.datacite+xml/10.1594/PANGAEA.771774"
      ],
      "seeAlso": [
        "https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Abstract.jsonld"
      ]
    },
