        "owl:NamedIndividual",
        "Concept"
      ],
      "prefLabel": "PeerReview",
      "notation": "PeerReview",
      "definition": "Evaluation of scientific, academic, or professional work by others working in the same field.",
      "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
      "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral",
