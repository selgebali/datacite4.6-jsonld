        <skos:definition xml:lang="en">An abstract, conceptual, graphical, mathematical or visualization model that represents empirical objects, phenomena, or physical processes.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Model.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
