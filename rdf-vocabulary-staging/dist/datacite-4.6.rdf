        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.6084/m9.figshare.5742270
&lt;resourceType resourceTypeGeneral="PeerReview"&gt;Scientific Article&lt;/resourceType&gt;</skos:scopeNote>
        <skos:prefLabel xml:lang="en">PeerReview</skos:prefLabel>
        <skos:notation>PeerReview</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:definition xml:lang="en">Evaluation of scientific, academic, or professional work by others working in the same field.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/PeerReview.jsonld"/>
      </skos:Concept>
