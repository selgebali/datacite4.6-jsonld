        <skos:scopeNote xml:lang="en">This is meant to be the instrument instance (the individual physical device), not the digital description or design of an instrument.
&lt;resourceType resourceTypeGeneral="Instrument"&gt;Reflectometer&lt;/resourceType&gt;</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Instrument</skos:prefLabel>
        <skos:notation>Instrument</skos:notation>
