        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:definition xml:lang="en">A scholarly publication consisting of articles that is published regularly throughout the year.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Journal.jsonld"/>
      </skos:Concept>
