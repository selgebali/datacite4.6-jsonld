      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/OutputManagementPlan">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">Includes data, software, and materials.
&lt;resourceType resourceTypeGeneral="OutputManagementPlan"&gt;Data Management Plan&lt;/resourceType&gt;</skos:scopeNote>
        <skos:prefLabel xml:lang="en">OutputManagementPlan</skos:prefLabel>
        <skos:notation>OutputManagementPlan</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:definition xml:lang="en">A formal document that outlines how research outputs are to be handled both during a research project and after the project is completed.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/OutputManagementPlan.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Model">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">Modelled descriptions of, for example, different aspects of languages or a molecular biology reaction chain</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Model</skos:prefLabel>
        <skos:notation>Model</skos:notation>
