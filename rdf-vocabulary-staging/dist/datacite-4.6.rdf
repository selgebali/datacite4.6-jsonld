        <skos:notation>Collection</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.1594/pangaea.877589</skos:example>
        <skos:definition xml:lang="en">An aggregation of resources, which may encompass collections of one resourceType as well as those of mixed types. A collection is described as a group; its parts may also be separately described.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Collection"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Collection.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/ComputationalNotebook">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">&lt;resourceType resourceTypeGeneral="ComputationalNotebook"&gt;Jupyter&lt;/resourceType&gt;</skos:scopeNote>
        <skos:prefLabel xml:lang="en">ComputationalNotebook</skos:prefLabel>
        <skos:notation>ComputationalNotebook</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:definition xml:lang="en">A virtual notebook environment used for literate programming.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#InteractiveResource"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/ComputationalNotebook.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/ConferencePaper">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">&lt;resourceType resourceTypeGeneral="ConferencePaper"&gt;Experience Report&lt;/resourceType&gt;</skos:scopeNote>
        <skos:prefLabel xml:lang="en">ConferencePaper</skos:prefLabel>
        <skos:notation>ConferencePaper</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:definition xml:lang="en">Article that is written with the goal of being accepted to a conference.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/ConferencePaper.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/ConferenceProceeding">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">&lt;resourceType resourceTypeGeneral="ConferenceProceeding"&gt;Annual Convention&lt;/resourceType&gt;</skos:scopeNote>
        <skos:prefLabel xml:lang="en">ConferenceProceeding</skos:prefLabel>
        <skos:notation>ConferenceProceeding</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:definition xml:lang="en">Collection of academic papers published in the context of an academic conference.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/ConferenceProceeding.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/DataPaper">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">A data paper describes data provenance and methodologies used in the gathering, processing, organizing, and representing the data</skos:scopeNote>
        <skos:prefLabel xml:lang="en">DataPaper</skos:prefLabel>
        <skos:notation>DataPaper</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.17912/w2mw2d</skos:example>
        <skos:definition xml:lang="en">A factual and objective publication with a focused intent to identify and describe specific data, sets of data, or data collections to facilitate discoverability.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/DataPaper.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Dataset">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">Data file or files</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Dataset</skos:prefLabel>
        <skos:notation>Dataset</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.1594/pangaea.804876</skos:example>
        <skos:definition xml:lang="en">Data encoded in a defined structure.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Dataset"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Dataset.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Dissertation">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">&lt;resourceType resourceTypeGeneral="Dissertation"&gt;PhD thesis&lt;/resourceType&gt;</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Dissertation</skos:prefLabel>
        <skos:notation>Dissertation</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:definition xml:lang="en">A written essay, treatise, or thesis, especially one written by a candidate for the degree of Doctor of Philosophy.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Dissertation.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
  </skos:ConceptScheme>
  <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType">
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/w3id">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">w3id</skos:prefLabel>
        <skos:notation>w3id</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="w3id" relationType="IsCitedBy"&gt;https://w3id.org/games/spec/coil#Coil_Bomb_Die_Of_Age&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">Mostly used to publish vocabularies and ontologies. The letters ‘w3’ stand for “World Wide Web”.</skos:definition>
        <skos:altLabel xml:lang="en">Permanent identifier for Web applications</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/w3id.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/URN">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">URN</skos:prefLabel>
        <skos:notation>URN</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URN" relationType="IsSupplementTo"&gt;urn:nbn:de:101:1-201102033592&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A unique and persistent identifier of an electronic document. The syntax is: urn:&lt;NID&gt;:&lt;NSS&gt;. The leading urn: sequence is case-insensitive, &lt;NID&gt; is the namespace identifier, &lt;NSS&gt; is the namespace-specific string.</skos:definition>
        <skos:altLabel xml:lang="en">Uniform Resource Name</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/URN.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/URL">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">URL</skos:prefLabel>
        <skos:notation>URL</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="IsCitedBy"&gt;http://www.heatflow.und.edu/index2.html&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">Also known as web address, a URL is a specific character string that constitutes a reference to a resource. The syntax is: scheme://domain:port/path?query_string#fragment_id.</skos:definition>
        <skos:altLabel xml:lang="en">Uniform Resource Locator</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/URL.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/UPC">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">UPC</skos:prefLabel>
        <skos:notation>UPC</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="UPC" relationType="Cites"&gt;123456789999&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A barcode symbology used for tracking trade items in stores. Its most common form, the UPC-A, consists of 12 numerical digits.</skos:definition>
        <skos:altLabel xml:lang="en">Universal Product Code</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/UPC.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/SWHID"/>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/RRID">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">RRID</skos:prefLabel>
        <skos:notation>RRID</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="RRID" relationType="Cites"&gt;RRID:SCR_014641&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A character string used to uniquely identify key inputs to an experiment including the so-called “key biological resources” as defined by the National Institutes of Health, and related tools such as core facilities and databases. An RRID name is divided into two parts, the authority and a local identifier, separated by an underscore.</skos:definition>
        <skos:altLabel xml:lang="en">Research Resource IDentifier</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/RRID.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/RAiD"/>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/PURL">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">PURL</skos:prefLabel>
        <skos:notation>PURL</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="PURL" relationType="Cites"&gt;http://purl.oclc.org/foo/bar&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A PURL has three parts: (1) a protocol, (2) a resolver address, and (3) a name.</skos:definition>
        <skos:altLabel xml:lang="en">Persistent Uniform Resource Locator</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/PURL.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/PMID">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">PMID</skos:prefLabel>
        <skos:notation>PMID</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="PMID" relationType="IsReferencedBy"&gt;12082125&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A unique number assigned to each PubMed record.</skos:definition>
        <skos:altLabel xml:lang="en">PubMed identifier</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/PMID.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/LSID">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">LSID</skos:prefLabel>
        <skos:notation>LSID</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="LSID" relationType="Cites"&gt;urn:lsid:ubio.org:namebank:11815&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A unique identifier for data in the Life Science domain. Format: urn:lsid:authority:namespace:identifier:revision.</skos:definition>
        <skos:altLabel xml:lang="en">Life Science Identifiers</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/LSID.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/LISSN">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">LISSN</skos:prefLabel>
        <skos:notation>LISSN</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="LISSN" relationType="Cites"&gt;1188-1534&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">The linking ISSN or ISSN-L enables collocation or linking among different media versions of a continuing resource.</skos:definition>
        <skos:altLabel xml:lang="en">Linking ISSN</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/LISSN.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISTC">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">ISTC</skos:prefLabel>
        <skos:notation>ISTC</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="ISTC" relationType="Cites"&gt;0A9 2002 12B4A105 7&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A unique “number” assigned to a textual work. An ISTC consists of 16 numbers and/or letters.</skos:definition>
        <skos:altLabel xml:lang="en">International Standard Text Code</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISTC.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date"
    >2026-02-20</dcterms:created>
    <dcterms:identifier>relatedIdentifierType</dcterms:identifier>
    <dcterms:title xml:lang="en">DataCite 4.6 relatedIdentifierType</dcterms:title>
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/relatedIdentifierType.jsonld"/>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ARK">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">ARK</skos:prefLabel>
        <skos:notation>ARK</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="ARK" relationType="IsCitedBy"&gt;ark:/13030/tqb3kh97gh8w&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A URI designed to support long-term access to information objects. In general, ARK syntax is of the form (brackets, []. indicate optional elements): [http://NMA/]ark:/NAAN/Name [Qualifier].</skos:definition>
        <skos:altLabel xml:lang="en">Archival Resource Key</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ARK.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/arXiv">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">arXiv</skos:prefLabel>
        <skos:notation>arXiv</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="arXiv" relationType="IsCitedBy"&gt;arXiv:0706.0001&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">arXiv.org is a repository of preprints of scientific papers in the fields of mathematics, physics, astronomy, computer science, quantitative biology, statistics, and quantitative finance.</skos:definition>
        <skos:altLabel xml:lang="en">arXiv identifier</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/arXiv.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/bibcode">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">bibcode</skos:prefLabel>
        <skos:notation>bibcode</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="bibcode" relationType="IsCitedBy"&gt;2018AGUFM.A24K..07S&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A standardized 19-character identifier according to the syntax yyyyjjjjjvvvvmppppa. See http://info-uri.info/registry/OAIHandler?verb=GetRecord&amp;metadataPrefix=reg&amp;identifier=info:bibcode/. Note: bibcodes can be searched via https://ui.adsabs.harvard.edu/ or resolved using https://ui.adsabs.harvard.edu/abs/&lt;bibcode&gt;.</skos:definition>
        <skos:altLabel xml:lang="en">Astrophysics Data System bibliographic codes</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/bibcode.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/CSTR">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">CSTR</skos:prefLabel>
        <skos:notation>CSTR</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="CSTR" relationType="References"&gt;31253.11.sciencedb.13238&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">CSTR is an identifier based on the Chinese National Standard GB/T 32843—2016 “Science and technology resource identification”, providing a unique identification service for scientific data, papers, scientific institutions, researchers, scientific instruments, patents and other scientific and technological resources.</skos:definition>
        <skos:altLabel xml:lang="en">Common Science and Technology Resources Identifier</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/CSTR.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/DOI">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">DOI</skos:prefLabel>
        <skos:notation>DOI</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsSupplementTo"&gt;10.1016/j.epsl.2011.11.037&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A character string used to uniquely identify an object. A DOI name is divided into two parts, a prefix and a suffix, separated by a slash.</skos:definition>
        <skos:altLabel xml:lang="en">Digital Object Identifier</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/DOI.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/EAN13">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">EAN13</skos:prefLabel>
        <skos:notation>EAN13</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="EAN13" relationType="Cites"&gt;9783468111242&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A 13-digit barcoding standard that is a superset of the original 12-digit Universal Product Code (UPC) system.</skos:definition>
        <skos:altLabel xml:lang="en">European Article Number (now renamed International Article Number, but retaining the original acronym)</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/EAN13.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/EISSN">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">EISSN</skos:prefLabel>
        <skos:notation>EISSN</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="eISSN" relationType="Cites"&gt;1562-6865&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">ISSN used to identify periodicals in electronic form (eISSN or e-ISSN).</skos:definition>
        <skos:altLabel xml:lang="en">Electronic International Standard Serial Number</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/EISSN.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/Handle">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">Handle</skos:prefLabel>
        <skos:notation>Handle</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="Handle" relationType="References"&gt;10013/epic.10033&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">This refers specifically to an ID in the Handle system operated by the Corporation for National Research Initiatives (CNRI).</skos:definition>
        <skos:altLabel xml:lang="en">Handle</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/Handle.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/IGSN">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">IGSN</skos:prefLabel>
        <skos:notation>IGSN</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="IGSN" relationType="References"&gt;IECUR0097&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A code that uniquely identifies samples from our natural environment and related features-of-interest.</skos:definition>
        <skos:altLabel xml:lang="en">International Generic Sample Number</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/IGSN.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISBN">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">ISBN</skos:prefLabel>
        <skos:notation>ISBN</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="ISBN" relationType="IsPartOf"&gt;978-3-905673-82-1&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A unique numeric book identifier. There are 2 formats: a 10-digit ISBN format and a 13-digit ISBN.</skos:definition>
        <skos:altLabel xml:lang="en">International Standard Book Number</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISBN.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISSN">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:prefLabel xml:lang="en">ISSN</skos:prefLabel>
        <skos:notation>ISSN</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="ISSN" relationType="IsPartOf"&gt;0077-5606&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">A unique 8-digit number used to identify a print or electronic periodical publication.</skos:definition>
        <skos:altLabel xml:lang="en">International Standard Serial Number</skos:altLabel>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISSN.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
  </skos:ConceptScheme>
  <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType">
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Other">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">Could be a photographer, artist, or writer whose contribution helped to publicize the resource (as opposed to creating it), a reviewer, someone providing administrative services (depositing updates, analysing usage), etc.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Other</skos:prefLabel>
        <skos:notation>Other</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">Any person or institution making a significant contribution to the development and/or maintenance of the resource, but whose contribution is not adequately described by any of the other values for contributorType.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Other.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/WorkPackageLeader">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:prefLabel xml:lang="en">WorkPackageLeader</skos:prefLabel>
        <skos:notation>WorkPackageLeader</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">A Work Package is a recognized data product, not all of which is included in publication. The package may include notes, discarded documents, etc. The Work Package Leader is responsible for ensuring comprehensive contents, versioning, and availability of the Work Package during development of the resource.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/WorkPackageLeader.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Translator">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">Apply to DOI metadata for a resource which has been translated from another resource.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Translator</skos:prefLabel>
        <skos:notation>Translator</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">A person, organization, or automated system responsible for converting the content of a resource from one language into another, preserving its meaning and intended message.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Translator.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Supervisor">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:prefLabel xml:lang="en">Supervisor</skos:prefLabel>
        <skos:notation>Supervisor</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">Designated administrator over one or more groups/teams working to produce a resource, or over one or more steps of a development process.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Supervisor.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Sponsor">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">Includes organisations that provide in-kind support (donation, people, facility, instrumentation) necessary for development of the resource.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Sponsor</skos:prefLabel>
        <skos:notation>Sponsor</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">Person or organisation that issued a contract or under the auspices of which a work has been written, printed, published, developed, etc.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Sponsor.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RightsHolder">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:prefLabel xml:lang="en">RightsHolder</skos:prefLabel>
        <skos:notation>RightsHolder</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">Person or institution owning or managing property rights, including intellectual property rights over the resource.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RightsHolder.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ResearchGroup">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">May operate at a narrower level of scope; may or may not hold less administrative responsibility than a project team.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">ResearchGroup</skos:prefLabel>
        <skos:notation>ResearchGroup</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:example>doi:10.26302/SSHADE/EXPERIMEN T_OP_20201104_001</skos:example>
        <skos:example>Space Research &amp; Planetary Sciences Division of the University of Bern (WP Unibe)</skos:example>
        <skos:definition xml:lang="en">Typically refers to a group of individuals with a lab, department, or division that has a specifically defined focus of activity.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ResearchGroup.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Researcher">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">Should be a person, not an institution. A person gathering data would typically be DataCollector. A researcher may find additional data online and correlate it to collected data.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Researcher</skos:prefLabel>
        <skos:notation>Researcher</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">A person involved in analysing data or the results of an experiment or formal study.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Researcher.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RelatedPerson">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">Could be an author’s intellectual mentor, a person providing intellectual leadership in the discipline or subject domain, etc.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">RelatedPerson</skos:prefLabel>
        <skos:notation>RelatedPerson</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">A person without a specifically defined role in the development of the resource, but who is someone the author wishes to recognize.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RelatedPerson.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RegistrationAuthority">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">The IDF serves as the Registration Authority for the International Standards Organisation (ISO) in the area/domain of Digital Object Identifiers.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">RegistrationAuthority</skos:prefLabel>
        <skos:notation>RegistrationAuthority</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">A standards-setting body from which Registration Agencies obtain official recognition and guidance.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RegistrationAuthority.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RegistrationAgency">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">DataCite is a Registration Agency for the International DOI Foundation (IDF). One task is to assign DOI prefixes to allocating agents who then assign full DOI strings to clients and provide metadata back to the DataCite registry.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">RegistrationAgency</skos:prefLabel>
        <skos:notation>RegistrationAgency</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">Institution/organisation officially appointed by a Registration Authority to handle specific tasks within a defined area of responsibility.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RegistrationAgency.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date"
    >2026-01-18</dcterms:created>
    <dcterms:identifier>contributorType</dcterms:identifier>
    <dcterms:title xml:lang="en">DataCite 4.6 contributorType</dcterms:title>
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/contributorType.jsonld"/>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ContactPerson">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">May also be the “Point of Contact” in an organisation that controls access to the resource, if that organisation is different from the Publisher, Distributor, and Data Manager.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">ContactPerson</skos:prefLabel>
        <skos:notation>ContactPerson</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">Person with knowledge of how to access, troubleshoot, or otherwise field issues related to the resource.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ContactPerson.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataCollector">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">May also be used when crediting survey conductors, interviewers, event or condition observers, or persons responsible for monitoring key instrument data.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">DataCollector</skos:prefLabel>
        <skos:notation>DataCollector</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">Person/institution responsible for finding or gathering/collecting data under the guidelines of the author(s) or Principal Investigator (PI).</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataCollector.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataCurator">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">While the DataManager is concerned with digital maintenance, the DataCurator’s role encompasses quality assurance focused on content and metadata. Responsibilities can include checking completeness; verifying standard metadata; adding/verifying specialized metadata; and determining how metadata maps to search engines, database products, and automated feeds. Repository managers and data librarians may fall within this category.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">DataCurator</skos:prefLabel>
        <skos:notation>DataCurator</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:example>https://doi.org/10.20375/0000-000D-1D1F-2</skos:example>
        <skos:definition xml:lang="en">Person tasked with reviewing, enhancing, cleaning, or standardizing metadata and the associated data submitted for storage, use, and maintenance within a data centre or repository.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataCurator.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataManager">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">Ensures the resource is periodically refreshed (software/hardware support), kept available/protected from unauthorized access, stored according to industry standards, and handled according to applicable records management requirements.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">DataManager</skos:prefLabel>
        <skos:notation>DataManager</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:example>https://doi.org/10.6073/pasta/41b3ed2e152e1e4c3846e646118208e7</skos:example>
        <skos:definition xml:lang="en">Person (or organisation with a staff of data managers, such as a data centre) responsible for maintaining the finished resource.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataManager.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Distributor">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">Works stored in more than one archive/repository may credit each as a distributor.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Distributor</skos:prefLabel>
        <skos:notation>Distributor</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">Institution tasked with responsibility to generate/disseminate copies of the resource in either electronic or print form.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Distributor.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Editor">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">If the Editor is to be credited in place of multiple creators, the Editor’s name may be supplied as Creator, with “(Ed.)” appended to the name.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Editor</skos:prefLabel>
        <skos:notation>Editor</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">A person who oversees the details related to the publication format of the resource.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Editor.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/HostingInstitution">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">This role normally falls on the university, research center, or organization where the data center/repository belongs. May also be used for an organisation that stores the data offline, often a data centre if that data centre is not the publisher.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">HostingInstitution</skos:prefLabel>
        <skos:notation>HostingInstitution</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:example>Université Grenoble Alpes (UGA)</skos:example>
        <skos:definition xml:lang="en">Typically, the organisation allowing the resource to be available on the internet through the provision of its hardware/software/operating support.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/HostingInstitution.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Producer">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">In the data industry, this may be a company producing DVDs that package data for future dissemination by a distributor.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Producer</skos:prefLabel>
        <skos:notation>Producer</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">Typically, a person or organisation responsible for the artistry and form of a media product.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Producer.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectLeader">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">The Project Leader remains intimately involved throughout the life of the particular project team.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">ProjectLeader</skos:prefLabel>
        <skos:notation>ProjectLeader</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">Person officially designated as head of project team or sub-project team instrumental in the work necessary to development of the resource.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectLeader.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectManager">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">The manager of a project normally has more administrative responsibility than actual work involvement.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">ProjectManager</skos:prefLabel>
        <skos:notation>ProjectManager</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">Person officially designated as manager of a project. Project may consist of one or many project teams and sub-teams.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectManager.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectMember">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:scopeNote xml:lang="en">This vocabulary may or may not indicate the quality, quantity, or substance of the person’s involvement.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">ProjectMember</skos:prefLabel>
        <skos:notation>ProjectMember</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
        <skos:definition xml:lang="en">Person on the membership list of a designated project/project team.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectMember.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
  </skos:ConceptScheme>
  <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/nameType">
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/nameType/Personal">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/nameType"/>
        <skos:prefLabel xml:lang="en">Personal</skos:prefLabel>
        <skos:notation>Personal</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/nameType"/>
        <skos:definition xml:lang="en">An individual person’s name.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/nameType/Personal.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/nameType/Organizational">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/nameType"/>
        <skos:prefLabel xml:lang="en">Organizational</skos:prefLabel>
        <skos:notation>Organizational</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/nameType"/>
        <skos:definition xml:lang="en">An organization or institution name.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/nameType/Organizational.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/nameType/nameType.jsonld"/>
    <dcterms:title xml:lang="en">DataCite 4.6 nameType</dcterms:title>
    <dcterms:identifier>nameType</dcterms:identifier>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date"
    >2026-02-20</dcterms:created>
  </skos:ConceptScheme>
  <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType">
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Other">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
        <skos:scopeNote xml:lang="en">Use for any other description type.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Other</skos:prefLabel>
        <skos:notation>Other</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
        <skos:definition xml:lang="en">Other description information that does not fit into an existing category.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Other.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/TechnicalInfo">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
        <skos:scopeNote xml:lang="en">For software description, this may include the contents of a “readme.txt” and necessary environmental information (hardware, operational software, applications/programs with version information, a human-readable synopsis of software purpose) that cannot be described using other properties. For other uses, this can include specific and detailed information as necessary and appropriate.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">TechnicalInfo</skos:prefLabel>
        <skos:notation>TechnicalInfo</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
        <skos:definition xml:lang="en">Detailed information that may be associated with design, implementation, operation, use, and/or maintenance of a process, system, or instrument.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/TechnicalInfo.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/TableOfContents">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
        <skos:scopeNote xml:lang="en">Use “&lt;br&gt;” to indicate a line break for improved rendering of multiple paragraphs, but otherwise no html markup.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">TableOfContents</skos:prefLabel>
        <skos:notation>TableOfContents</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
        <skos:example>https://data.datacite.org/application/vnd.datacite.datacite+xml/10.5678/LCRS/FOR816.CIT.1031</skos:example>
        <skos:definition xml:lang="en">A listing of the Table of Contents.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/TableOfContents.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/SeriesInformation">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
        <skos:scopeNote xml:lang="en">The information previously encoded as a description with this type should now be explicitly provided in tagged fields using the new RelatedItem property with relationType “IsPublishedIn” selected.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">SeriesInformation</skos:prefLabel>
        <skos:notation>SeriesInformation</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
        <skos:definition xml:lang="en">Information about a repeating series, such as volume, issue, number.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/SeriesInformation.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Methods">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
        <skos:scopeNote xml:lang="en">Recommended for discovery. Full documentation about methods supports open science.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Methods</skos:prefLabel>
        <skos:notation>Methods</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
        <skos:example>https://data.datacite.org/application/vnd.datacite.datacite+xml/10.6078/D1K01X</skos:example>
        <skos:definition xml:lang="en">The methodology employed for the study or research.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Methods.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Abstract">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
        <skos:scopeNote xml:lang="en">Recommended for discovery. Use “&lt;br&gt;” to indicate a line break for improved rendering of multiple paragraphs, but otherwise no html markup.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Abstract</skos:prefLabel>
        <skos:notation>Abstract</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
        <skos:example>https://data.datacite.org/application/vnd.datacite.datacite+xml/10.1594/PANGAEA.771774</skos:example>
        <skos:definition xml:lang="en">A brief description of the resource and the context in which the resource was created.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Abstract.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/descriptionType.jsonld"/>
    <dcterms:title xml:lang="en">DataCite 4.6 descriptionType</dcterms:title>
    <dcterms:identifier>descriptionType</dcterms:identifier>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date"
    >2026-02-20</dcterms:created>
  </skos:ConceptScheme>
  <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType">
    <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Other"/>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasTranslation">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">When a resource is shared in one language and later translated, use HasTranslation to link original to translation. If released simultaneously in multiple languages, connect in both directions.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">HasTranslation</skos:prefLabel>
        <skos:notation>HasTranslation</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="HasTranslation"&gt;10.21384/g01j-jm06&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A has a translation B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasTranslation.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsTranslationOf">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">When a resource is shared in one language and later translated, use IsTranslationOf to link translation to original.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsTranslationOf</skos:prefLabel>
        <skos:notation>IsTranslationOf</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsTranslationOf"&gt;10.21384/828a-cm38&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is a translation of B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsTranslationOf.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Collects">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">May indicate relationship between an instrument and a dataset it collected/observed.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Collects</skos:prefLabel>
        <skos:notation>Collects</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Collects"&gt;10.5072/data&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">Indicates A collects B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Collects.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCollectedBy">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">May indicate relationship between a dataset and an instrument used to collect/measure/observe data.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsCollectedBy</skos:prefLabel>
        <skos:notation>IsCollectedBy</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsCollectedBy"&gt;10.5072/instrument&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">Indicates A is collected by B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCollectedBy.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsObsoletedBy">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">IsObsoletedBy</skos:prefLabel>
        <skos:notation>IsObsoletedBy</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsObsoletedBy"&gt;10.5438/0005&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">Indicates A is replaced by B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsObsoletedBy.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Obsoletes">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">Obsoletes</skos:prefLabel>
        <skos:notation>Obsoletes</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Obsoletes"&gt;10.5438/0007&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">Indicates A replaces B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Obsoletes.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Requires">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">May be used to indicate software dependencies.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Requires</skos:prefLabel>
        <skos:notation>Requires</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Requires"&gt;10.1234/867&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">Indicates A requires B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Requires.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsRequiredBy">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">May be used to indicate software dependencies.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsRequiredBy</skos:prefLabel>
        <skos:notation>IsRequiredBy</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsRequiredBy"&gt;10.1234/8675&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">Indicates A is required by B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsRequiredBy.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSourceOf">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">IsSourceOf is the original resource from which a derivative resource was created (e.g., original dataset without value manipulation).</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsSourceOf</skos:prefLabel>
        <skos:notation>IsSourceOf</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="IsSourceOf"&gt;http://opencontext.org/projects/81204AF8-127C-4686-E9B0-1202C3A47959&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is a source upon which B is based</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSourceOf.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDerivedFrom">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">Use for a resource that is a derivative of an original resource. Example context: dataset derived from a larger dataset and manipulated.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsDerivedFrom</skos:prefLabel>
        <skos:notation>IsDerivedFrom</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsDerivedFrom"&gt;10.6078/M7DZ067C&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates B is a source upon which A is based</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDerivedFrom.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Reviews">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">Reviews</skos:prefLabel>
        <skos:notation>Reviews</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Reviews"&gt;10.12688/f1000research.4001.1&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates that A is a review of B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Reviews.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsReviewedBy">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">IsReviewedBy</skos:prefLabel>
        <skos:notation>IsReviewedBy</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsReviewedBy"&gt;10.5256/F1000RESEARCH.4288.R4745&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates that A is reviewed by B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsReviewedBy.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsIdenticalTo">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">Use when the same resource is saved in another location (e.g., another institution).</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsIdenticalTo</skos:prefLabel>
        <skos:notation>IsIdenticalTo</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="IsIdenticalTo"&gt;http://oac.cdlib.org/findaid/ark:/13030/c8r78fzq&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates that A is identical to B, for use when there is a need to register two separate instances of the same resource</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsIdenticalTo.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsOriginalFormOf">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">May be used for different software operating systems or compiler formats.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsOriginalFormOf</skos:prefLabel>
        <skos:notation>IsOriginalFormOf</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsOriginalFormOf"&gt;10.1234/9035&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is the original form of B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsOriginalFormOf.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsVariantFormOf">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">Use for a different form of one thing. May be used for different software operating systems or compiler formats.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsVariantFormOf</skos:prefLabel>
        <skos:notation>IsVariantFormOf</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsVariantFormOf"&gt;10.1234/8675&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is a variant or different form of B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsVariantFormOf.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Compiles">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">May be used for software and text; a compiler can be a computer program or a person.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Compiles</skos:prefLabel>
        <skos:notation>Compiles</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URN" relationType="Compiles"&gt;urn:nbn:de:bsz:21-opus-963&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates B is the result of a compile or creation event using A</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Compiles.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCompiledBy">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">May indicate a traditional text compilation, or the compiler program used to generate executable software.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsCompiledBy</skos:prefLabel>
        <skos:notation>IsCompiledBy</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="IsCompiledBy"&gt;http://d-nb.info/gnd/4513749-3&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates B is used to compile or create A</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCompiledBy.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Documents">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">May be used for software documentation.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Documents</skos:prefLabel>
        <skos:notation>Documents</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Documents"&gt;10.1234/7836&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is documentation about/explaining B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Documents.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDocumentedBy">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">May be used for software documentation.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsDocumentedBy</skos:prefLabel>
        <skos:notation>IsDocumentedBy</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="IsDocumentedBy"&gt;http://tobias-lib.uni-tuebingen.de/volltexte/2000/96/&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates B is documentation about/explaining A</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDocumentedBy.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/References">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">Recommended for discovery.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">References</skos:prefLabel>
        <skos:notation>References</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URN" relationType="References"&gt;urn:nbn:de:bsz:21-opus-963&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates B is used as a source of information for A</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/References.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsReferencedBy">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">Recommended for discovery.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsReferencedBy</skos:prefLabel>
        <skos:notation>IsReferencedBy</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="IsReferencedBy"&gt;http://www.testpubl.de&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is used as a source of information by B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsReferencedBy.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsPublishedIn">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">IsPublishedIn</skos:prefLabel>
        <skos:notation>IsPublishedIn</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="ISSN" relationType="IsPublishedIn"&gt;2213-1337&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is published inside B, but is independent of other things published inside of B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsPublishedIn.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasPart">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">Recommended for discovery. Primarily applied to container-contained relationships. May be used for individual software modules; code repository-to-version should use IsVersionOf/HasVersion.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">HasPart</skos:prefLabel>
        <skos:notation>HasPart</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="HasPart"&gt;https://zenodo.org/record/16564/files/dune-stuff-LSSC_15.zip&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A includes the part B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasPart.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsPartOf">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">Recommended for discovery. Primarily applied to container-contained relationships. May be used for individual software modules; code repository-to-version should use IsVersionOf/HasVersion.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsPartOf</skos:prefLabel>
        <skos:notation>IsPartOf</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsPartOf"&gt;10.5281/zenodo.754312&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is a portion of B; may be used for elements of a series</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsPartOf.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsPreviousVersionOf">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">IsPreviousVersionOf</skos:prefLabel>
        <skos:notation>IsPreviousVersionOf</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsPreviousVersionOf"&gt;10.5438/0007&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is a previous edition of B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsPreviousVersionOf.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsNewVersionOf">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">IsNewVersionOf</skos:prefLabel>
        <skos:notation>IsNewVersionOf</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsNewVersionOf"&gt;10.5438/0005&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is a new edition of B, where the new edition has been modified or updated</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsNewVersionOf.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsVersionOf">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">The registered resource is an instance of a target resource (A is an instance of B). May relate a specific software version to its code repository.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsVersionOf</skos:prefLabel>
        <skos:notation>IsVersionOf</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsVersionOf"&gt;10.5281/ZENODO.832054&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is a version of B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsVersionOf.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date"
    >2026-02-20</dcterms:created>
    <dcterms:identifier>relationType</dcterms:identifier>
    <dcterms:title xml:lang="en">DataCite 4.6 relationType</dcterms:title>
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/relationType.jsonld"/>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCitedBy">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">Recommended for discovery.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsCitedBy</skos:prefLabel>
        <skos:notation>IsCitedBy</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsCitedBy"&gt;10.4232/10.ASEAS-5.2-1&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates that B includes A in a citation</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCitedBy.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Cites">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">Recommended for discovery.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Cites</skos:prefLabel>
        <skos:notation>Cites</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="ISBN" relationType="Cites"&gt;0761964312&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates that A includes B in a citation</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Cites.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSupplementTo">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">Recommended for discovery.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsSupplementTo</skos:prefLabel>
        <skos:notation>IsSupplementTo</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URN" relationType="IsSupplementTo"&gt;urn:nbn:de:0168-ssoar-13172&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates that A is a supplement to B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSupplementTo.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSupplementedBy">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">Recommended for discovery.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">IsSupplementedBy</skos:prefLabel>
        <skos:notation>IsSupplementedBy</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="PMID" relationType="IsSupplementedBy"&gt;16911322&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates that B is a supplement to A</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSupplementedBy.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsContinuedBy">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">IsContinuedBy</skos:prefLabel>
        <skos:notation>IsContinuedBy</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URN" relationType="IsContinuedBy"&gt;urn:nbn:de:bsz:21-opus-4967&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is continued by the work B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsContinuedBy.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Continues">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">Continues</skos:prefLabel>
        <skos:notation>Continues</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="URN" relationType="Continues"&gt;urn:nbn:de:bsz:21-opus-4966&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is a continuation of the work B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Continues.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Describes">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">Describes</skos:prefLabel>
        <skos:notation>Describes</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Describes"&gt;10.6084/m9.figshare.c.3288407&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A describes B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Describes.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDescribedBy">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">IsDescribedBy</skos:prefLabel>
        <skos:notation>IsDescribedBy</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsDescribedBy"&gt;10.1038/sdata.2016.123&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A is described by B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDescribedBy.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasMetadata">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">HasMetadata</skos:prefLabel>
        <skos:notation>HasMetadata</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="HasMetadata" relatedMetadataScheme="DDI-L" schemeURI="http://www.ddialliance.org/Specification/DDI-Lifecycle/3.1/XMLSchema/instance.xsd"&gt;10.1234/567890&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates resource A has additional metadata B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasMetadata.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsMetadataFor">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:prefLabel xml:lang="en">IsMetadataFor</skos:prefLabel>
        <skos:notation>IsMetadataFor</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsMetadataFor" relatedMetadataScheme="DDI-L" schemeURI="http://www.ddialliance.org/Specification/DDI-Lifecycle/3.1/XMLSchema/instance.xsd"&gt;10.1234/567891&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates additional metadata A for a resource B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsMetadataFor.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasVersion">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:scopeNote xml:lang="en">The registered resource such as a software package or code repository has a versioned instance (A has instance B). May relate an un-versioned code repository to a specific software version.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">HasVersion</skos:prefLabel>
        <skos:notation>HasVersion</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
        <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="HasVersion"&gt;10.5281/ZENODO.832053&lt;/relatedIdentifier&gt;</skos:example>
        <skos:definition xml:lang="en">indicates A has a version B</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasVersion.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
  </skos:ConceptScheme>
  <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType">
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Other">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:prefLabel xml:lang="en">Other</skos:prefLabel>
        <skos:notation>Other</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:definition xml:lang="en">Other date that does not fit into an existing category.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Other.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date"
    >2026-02-20</dcterms:created>
    <dcterms:identifier>dateType</dcterms:identifier>
    <dcterms:title xml:lang="en">DataCite 4.6 dateType</dcterms:title>
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/dateType.jsonld"/>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Accepted">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:scopeNote xml:lang="en">To indicate the start of an embargo period, use Accepted or Submitted, as appropriate.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Accepted</skos:prefLabel>
        <skos:notation>Accepted</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:definition xml:lang="en">The date that the publisher accepted the resource into their system.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Accepted.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Available">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:scopeNote xml:lang="en">To indicate the end of an embargo period, use Available.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Available</skos:prefLabel>
        <skos:notation>Available</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:definition xml:lang="en">The date the resource is made publicly available. May be a range.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Available.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Copyrighted">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:prefLabel xml:lang="en">Copyrighted</skos:prefLabel>
        <skos:notation>Copyrighted</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:definition xml:lang="en">The specific, documented date at which the resource receives a copyrighted status, if applicable.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Copyrighted.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Collected">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:scopeNote xml:lang="en">To indicate precise or particular timeframes in which research was conducted.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Collected</skos:prefLabel>
        <skos:notation>Collected</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:definition xml:lang="en">The date or date range in which the resource content was collected.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Collected.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Coverage">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:scopeNote xml:lang="en">To indicate the temporal coverage of the resource, use Coverage. This may be different from Collected.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Coverage</skos:prefLabel>
        <skos:notation>Coverage</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:definition xml:lang="en">The date or date range that the resource content applies to, describes, or covers.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Coverage.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Created">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:scopeNote xml:lang="en">Recommended for discovery.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Created</skos:prefLabel>
        <skos:notation>Created</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:definition xml:lang="en">The date the resource itself was put together; this could refer to a timeframe in ancient history, a date range, or a single date for a final component, e.g., the finalised file with all the data.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Created.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Issued">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:prefLabel xml:lang="en">Issued</skos:prefLabel>
        <skos:notation>Issued</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:definition xml:lang="en">The date that the resource is published or distributed, e.g., to a data centre.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Issued.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Submitted">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:scopeNote xml:lang="en">Recommended for discovery. To indicate the start of an embargo period, use Submitted or Accepted, as appropriate.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Submitted</skos:prefLabel>
        <skos:notation>Submitted</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:definition xml:lang="en">The date the creator submits the resource to the publisher. This could be different from Accepted if the publisher then applies a selection process.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Submitted.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Updated">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:prefLabel xml:lang="en">Updated</skos:prefLabel>
        <skos:notation>Updated</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:definition xml:lang="en">The date of the last update to the resource, when the resource is being added to. May be a range.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Updated.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Valid">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:prefLabel xml:lang="en">Valid</skos:prefLabel>
        <skos:notation>Valid</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:definition xml:lang="en">The date or date range during which the dataset or resource is accurate.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Valid.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Withdrawn">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:scopeNote xml:lang="en">It is good practice to include a Description that indicates the reason for the retraction or withdrawal.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Withdrawn</skos:prefLabel>
        <skos:notation>Withdrawn</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
        <skos:definition xml:lang="en">The date the resource is removed.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Withdrawn.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
  </skos:ConceptScheme>
</rdf:RDF>
