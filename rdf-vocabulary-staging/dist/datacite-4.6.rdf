        <skos:definition xml:lang="en">A resource requiring interaction from the user to be understood, executed, or experienced.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#InteractiveResource"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/InteractiveResource.jsonld"/>
