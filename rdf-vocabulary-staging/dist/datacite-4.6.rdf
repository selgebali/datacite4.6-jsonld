    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Report">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">&lt;resourceType resourceTypeGeneral="Report"&gt;Annual Report&lt;/resourceType&gt;</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Report</skos:prefLabel>
        <skos:notation>Report</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:definition xml:lang="en">A document that presents information in an organized format for a specific audience and purpose.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Report.jsonld"/>
      </skos:Concept>
