        <skos:definition xml:lang="en">A medium for recording information in the form of writing or images, typically composed of many pages bound together and protected by a cover.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
