        <skos:scopeNote xml:lang="en">Training modules, files that require use of a viewer (e.g., Flash), or query/response portals</skos:scopeNote>
        <skos:prefLabel xml:lang="en">InteractiveResource</skos:prefLabel>
        <skos:notation>InteractiveResource</skos:notation>
