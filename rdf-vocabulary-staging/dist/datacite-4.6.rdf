        <skos:scopeNote xml:lang="en">&lt;resourceType resourceTypeGeneral="Journal"&gt;&lt;/resourceType&gt;</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Journal</skos:prefLabel>
