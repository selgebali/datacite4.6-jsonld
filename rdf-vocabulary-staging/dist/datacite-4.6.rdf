<rdf:RDF
    xmlns:dcterms="http://purl.org/dc/terms/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:skos="http://www.w3.org/2004/02/skos/core#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#">
  <owl:Ontology rdf:about="https://schema.stage.datacite.org/linked-data/dist/datacite-4.6">
    <owl:versionInfo>4.6</owl:versionInfo>
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/dist/datacite-4.6.rdf"/>
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/dist/datacite-4.6.ttl"/>
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/dist/datacite-4.6.jsonld"/>
    <rdfs:comment xml:lang="en">Integrated distribution of the DataCite linked-data classes, properties, vocabulary schemes, and vocabulary terms for schema version 4.6.</rdfs:comment>
    <dcterms:title xml:lang="en">DataCite Linked Data 4.6 Distribution</dcterms:title>
    <dcterms:source rdf:resource="https://schema.stage.datacite.org/linked-data/manifest/datacite-4.6.json"/>
    <dcterms:license rdf:resource="https://www.apache.org/licenses/LICENSE-2.0"/>
    <dcterms:identifier>datacite-4.6</dcterms:identifier>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date"
    >2026-05-12</dcterms:created>
  </owl:Ontology>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/RelatedItem">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/RelatedItem.jsonld"/>
    <rdfs:label xml:lang="en">RelatedItem</rdfs:label>
    <rdfs:comment xml:lang="en">Information about a resource related to the one being registered.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Date">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Date.jsonld"/>
    <rdfs:label xml:lang="en">Date</rdfs:label>
    <rdfs:comment xml:lang="en">Different dates relevant to the work.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Description">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Description.jsonld"/>
    <rdfs:label xml:lang="en">Description</rdfs:label>
    <rdfs:comment xml:lang="en"> All additional information that does not fit in any of the other categories. May be used for technical information or detailed information associated with a scientific instrument.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/PublicationYear">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/PublicationYear.jsonld"/>
    <rdfs:label xml:lang="en">PublicationYear</rdfs:label>
    <rdfs:comment xml:lang="en">The year when the data was or will be made publicly available. In the case of resources such as software or dynamic data where there may be multiple releases in one year, include the Date property and sub-properties (dateType/dateInformation) to provide more information about the publication or release date details.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Contributor">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Contributor.jsonld"/>
    <rdfs:label xml:lang="en">Contributor</rdfs:label>
    <rdfs:comment xml:lang="en"> The institution or person responsible for collecting, managing, distributing, or otherwise contributing to the development of the resource. To supply multiple contributors, repeat this property. For software, if there is an alternate entity that “holds, archives, publishes, prints, distributes, releases, issues, or produces” the code, use the contributorType “HostingInstitution” for the code repository. For instruments, if there is an institution responsible for the management of the instrument (for example, the legal owner, the operator, or an institute providing access to the instrument), use the contributorType “HostingInstitution” for the owner of the instrument.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Format">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Format.jsonld"/>
    <rdfs:label xml:lang="en">Format</rdfs:label>
    <rdfs:comment xml:lang="en">Technical format of the resource.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Subject">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Subject.jsonld"/>
    <rdfs:label xml:lang="en">Subject</rdfs:label>
    <rdfs:comment xml:lang="en">Subject, keyword, classification code, or key phrase describing the resource.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/AlternateIdentifier">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/AlternateIdentifier.jsonld"/>
    <rdfs:label xml:lang="en">AlternateIdentifier</rdfs:label>
    <rdfs:comment xml:lang="en">An identifier other than the primary Identifier applied to the resource being registered. This may be any alphanumeric string which is unique within its domain of issue. May be used for local identifiers, a serial number of an instrument or an inventory number. The AlternateIdentifier should be an additional identifier for the same instance of the resource (i.e., same location, same file).</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/RelatedIdentifier">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/RelatedIdentifier.jsonld"/>
    <rdfs:label xml:lang="en">RelatedIdentifier</rdfs:label>
    <rdfs:comment xml:lang="en">Identifiers of related resources. These must be globally unique identifiers.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Creator">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Creator.jsonld"/>
    <rdfs:label xml:lang="en">Creator</rdfs:label>
    <rdfs:comment xml:lang="en">The main researchers involved in producing the data, or the authors of the publication, in priority order. For instruments this is the manufacturer or developer of the instrument. To supply multiple creators, repeat this property.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Resource">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Resource.jsonld"/>
    <rdfs:label xml:lang="en">Resource</rdfs:label>
    <rdfs:comment xml:lang="en">Any object (data, software, instrument, document, sample, etc.) that can be cited via a DataCite-assigned persistent identifier (DOI). This is the root class of the DataCite Metadata Schema; every DataCite record describes exactly one Resource.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Publisher">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Publisher.jsonld"/>
    <rdfs:label xml:lang="en">Publisher</rdfs:label>
    <rdfs:comment xml:lang="en">The name of the entity that holds, archives, publishes, prints, distributes, releases, issues, or produces the resource. This property will be used to formulate the citation, so consider the prominence of the role.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Identifier">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Identifier.jsonld"/>
    <rdfs:label xml:lang="en">Identifier</rdfs:label>
    <rdfs:comment xml:lang="en">The Identifier is a unique string that identifies a resource.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Size">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Size.jsonld"/>
    <rdfs:label xml:lang="en">Size</rdfs:label>
    <rdfs:comment xml:lang="en">Size (e.g., bytes, pages, inches, etc.) or duration (extent), e.g., hours, minutes, days, etc., of a resource.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Rights">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Rights.jsonld"/>
    <rdfs:label xml:lang="en">Rights</rdfs:label>
    <rdfs:comment xml:lang="en">Any rights information for this resource.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Version">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Version.jsonld"/>
    <rdfs:label xml:lang="en">Version</rdfs:label>
    <rdfs:comment xml:lang="en">The version number of the resource.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/GeoLocation">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/GeoLocation.jsonld"/>
    <rdfs:label xml:lang="en">GeoLocation</rdfs:label>
    <rdfs:comment xml:lang="en">Spatial region or named place where the data was gathered or about which the data is focused.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Title">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Title.jsonld"/>
    <rdfs:label xml:lang="en">Title</rdfs:label>
    <rdfs:comment xml:lang="en">A name or title by which a resource is known. May be the title of a dataset or the name of a piece of software or an instrument.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/ResourceType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/ResourceType.jsonld"/>
    <rdfs:label xml:lang="en">ResourceType</rdfs:label>
    <rdfs:comment xml:lang="en">A description of the resource.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/FundingReference">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/FundingReference.jsonld"/>
    <rdfs:label xml:lang="en">FundingReference</rdfs:label>
    <rdfs:comment xml:lang="en">Information about financial support (funding) for the resource being registered.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Language">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/class/Language.jsonld"/>
    <rdfs:label xml:lang="en">Language</rdfs:label>
    <rdfs:comment xml:lang="en">The primary language of the resource.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/schemeType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/schemeType.jsonld"/>
    <rdfs:label xml:lang="en">schemeType</rdfs:label>
    <rdfs:comment xml:lang="en">The type of the relatedMetadataScheme, linked with the schemeURI.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/numberType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/numberType.jsonld"/>
    <rdfs:label xml:lang="en">numberType</rdfs:label>
    <rdfs:comment xml:lang="en">Type of the related item’s number, e.g., report number or article number.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/issue">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/issue.jsonld"/>
    <rdfs:label xml:lang="en">issue</rdfs:label>
    <rdfs:comment xml:lang="en">Issue number or name of the related item.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/pointLatitude">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/pointLatitude.jsonld"/>
    <rdfs:label xml:lang="en">pointLatitude</rdfs:label>
    <rdfs:comment xml:lang="en">Latitudinal dimension of point.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/westBoundLongitude">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/westBoundLongitude.jsonld"/>
    <rdfs:label xml:lang="en">westBoundLongitude</rdfs:label>
    <rdfs:comment xml:lang="en">Western longitudinal dimension of box.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/awardTitle">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/awardTitle.jsonld"/>
    <rdfs:label xml:lang="en">awardTitle</rdfs:label>
    <rdfs:comment xml:lang="en">The human readable title or name of the award (grant).</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/descriptionType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/descriptionType.jsonld"/>
    <rdfs:label xml:lang="en">descriptionType</rdfs:label>
    <rdfs:comment xml:lang="en">The type of the Description.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/geoLocationBox">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/geoLocationBox.jsonld"/>
    <rdfs:label xml:lang="en">geoLocationBox</rdfs:label>
    <rdfs:comment xml:lang="en">The spatial limits of a box.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/schemeURI">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/schemeURI.jsonld"/>
    <rdfs:label xml:lang="en">schemeURI</rdfs:label>
    <rdfs:comment xml:lang="en">The URI of an identifier scheme.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/funderIdentifier">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/funderIdentifier.jsonld"/>
    <rdfs:label xml:lang="en">funderIdentifier</rdfs:label>
    <rdfs:comment xml:lang="en">Uniquely identifies a funding entity, according to various types.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/geoLocationPolygon">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/geoLocationPolygon.jsonld"/>
    <rdfs:label xml:lang="en">geoLocationPolygon</rdfs:label>
    <rdfs:comment xml:lang="en">A drawn polygon area, defined by a set of points and lines connecting the points in a closed chain.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/nameIdentifierScheme">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/nameIdentifierScheme.jsonld"/>
    <rdfs:label xml:lang="en">nameIdentifierScheme</rdfs:label>
    <rdfs:comment xml:lang="en">The name of the name identifier scheme.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/format">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/format.jsonld"/>
    <rdfs:label xml:lang="en">format</rdfs:label>
    <rdfs:comment xml:lang="en">Technical format of the resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/contributorType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/contributorType.jsonld"/>
    <rdfs:label xml:lang="en">contributorType</rdfs:label>
    <rdfs:comment xml:lang="en">The type of contributor of the resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/dateType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/dateType.jsonld"/>
    <rdfs:label xml:lang="en">dateType</rdfs:label>
    <rdfs:comment xml:lang="en">The type of date.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/rightsIdentifier">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/rightsIdentifier.jsonld"/>
    <rdfs:label xml:lang="en">rightsIdentifier</rdfs:label>
    <rdfs:comment xml:lang="en">A short standardized identifier for the licence.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/publisherIdentifier">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/publisherIdentifier.jsonld"/>
    <rdfs:label xml:lang="en">publisherIdentifier</rdfs:label>
    <rdfs:comment xml:lang="en">Uniquely identifies the publisher, according to various schemes.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/nameType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/nameType.jsonld"/>
    <rdfs:label xml:lang="en">nameType</rdfs:label>
    <rdfs:comment xml:lang="en">The type of name.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/pointLongitude">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/pointLongitude.jsonld"/>
    <rdfs:label xml:lang="en">pointLongitude</rdfs:label>
    <rdfs:comment xml:lang="en">Longitudinal dimension of point.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/geoLocationPlace">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/geoLocationPlace.jsonld"/>
    <rdfs:label xml:lang="en">geoLocationPlace</rdfs:label>
    <rdfs:comment xml:lang="en">Description of a geographic location.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/familyName">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/familyName.jsonld"/>
    <rdfs:label xml:lang="en">familyName</rdfs:label>
    <rdfs:comment xml:lang="en">The surname or last name of the creator.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/publisher">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/publisher.jsonld"/>
    <rdfs:label xml:lang="en">publisher</rdfs:label>
    <rdfs:comment xml:lang="en">The name of the entity that holds, archives, publishes, prints, distributes, releases, issues, or produces the resource. This property will be used to formulate the citation, so consider the prominence of the role.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/valueURI">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/valueURI.jsonld"/>
    <rdfs:label xml:lang="en">valueURI</rdfs:label>
    <rdfs:comment xml:lang="en"> The URI of the subject term.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/edition">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/edition.jsonld"/>
    <rdfs:label xml:lang="en">edition</rdfs:label>
    <rdfs:comment xml:lang="en">Edition or version of the related item.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/dateInformation">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/dateInformation.jsonld"/>
    <rdfs:label xml:lang="en">dateInformation</rdfs:label>
    <rdfs:comment xml:lang="en">Specific information about the date, if appropriate.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/affiliationIdentifier">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/affiliationIdentifier.jsonld"/>
    <rdfs:label xml:lang="en">affiliationIdentifier</rdfs:label>
    <rdfs:comment xml:lang="en">Uniquely identifies the organizational affiliation of the creator.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedItem">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/relatedItem.jsonld"/>
    <rdfs:label xml:lang="en">relatedItem</rdfs:label>
    <rdfs:comment xml:lang="en">Information about a resource related to the one being registered.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/givenName">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/givenName.jsonld"/>
    <rdfs:label xml:lang="en">givenName</rdfs:label>
    <rdfs:comment xml:lang="en">The personal or first name of the creator.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/nameIdentifier">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/nameIdentifier.jsonld"/>
    <rdfs:label xml:lang="en">nameIdentifier</rdfs:label>
    <rdfs:comment xml:lang="en">Uniquely identifies an individual or legal entity, according to various schemes.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/funderIdentifierType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/funderIdentifierType.jsonld"/>
    <rdfs:label xml:lang="en">funderIdentifierType</rdfs:label>
    <rdfs:comment xml:lang="en">The type of the funderIdentifier.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/resourceType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/resourceType.jsonld"/>
    <rdfs:label xml:lang="en">resourceType</rdfs:label>
    <rdfs:comment xml:lang="en">A description of the resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/date">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/date.jsonld"/>
    <rdfs:label xml:lang="en">date</rdfs:label>
    <rdfs:comment xml:lang="en">Different dates relevant to the work.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/publisherIdentifierScheme">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/publisherIdentifierScheme.jsonld"/>
    <rdfs:label xml:lang="en">publisherIdentifierScheme</rdfs:label>
    <rdfs:comment xml:lang="en">The name of the publisher identifier scheme.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/funderName">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/funderName.jsonld"/>
    <rdfs:label xml:lang="en">funderName</rdfs:label>
    <rdfs:comment xml:lang="en">Name of the funding provider.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedIdentifierType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/relatedIdentifierType.jsonld"/>
    <rdfs:label xml:lang="en">relatedIdentifierType</rdfs:label>
    <rdfs:comment xml:lang="en">The type of the RelatedIdentifier.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/titleType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/titleType.jsonld"/>
    <rdfs:label xml:lang="en">titleType</rdfs:label>
    <rdfs:comment xml:lang="en">The type of Title (other than the Main Title).</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedItemIdentifier">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/relatedItemIdentifier.jsonld"/>
    <rdfs:label xml:lang="en">relatedItemIdentifier</rdfs:label>
    <rdfs:comment xml:lang="en">The identifier for the related item.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/geoLocation">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/geoLocation.jsonld"/>
    <rdfs:label xml:lang="en">geoLocation</rdfs:label>
    <rdfs:comment xml:lang="en">Spatial region or named place where the data was gathered or about which the data is focused.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/identifier">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/identifier.jsonld"/>
    <rdfs:label xml:lang="en">identifier</rdfs:label>
    <rdfs:comment xml:lang="en">The Identifier is a unique string that identifies a resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/resourceTypeGeneral">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/resourceTypeGeneral.jsonld"/>
    <rdfs:label xml:lang="en">resourceTypeGeneral</rdfs:label>
    <rdfs:comment xml:lang="en">The general type of a resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/version">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/version.jsonld"/>
    <rdfs:label xml:lang="en">version</rdfs:label>
    <rdfs:comment xml:lang="en">The version number of the resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/inPolygonPoint">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/inPolygonPoint.jsonld"/>
    <rdfs:label xml:lang="en">inPolygonPoint</rdfs:label>
    <rdfs:comment xml:lang="en">A point location in a polygon.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/number">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/number.jsonld"/>
    <rdfs:label xml:lang="en">number</rdfs:label>
    <rdfs:comment xml:lang="en">Number of the resource within the related item, e.g., report number or article number.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedItemType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/relatedItemType.jsonld"/>
    <rdfs:label xml:lang="en">relatedItemType</rdfs:label>
    <rdfs:comment xml:lang="en">The general type of the related item.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/subject">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/subject.jsonld"/>
    <rdfs:label xml:lang="en">subject</rdfs:label>
    <rdfs:comment xml:lang="en">Subject, keyword, classification code, or key phrase describing the resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/subjectScheme">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/subjectScheme.jsonld"/>
    <rdfs:label xml:lang="en">subjectScheme</rdfs:label>
    <rdfs:comment xml:lang="en">The name of the subject scheme or classification code or authority if one is used.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedIdentifier">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/relatedIdentifier.jsonld"/>
    <rdfs:label xml:lang="en">relatedIdentifier</rdfs:label>
    <rdfs:comment xml:lang="en">Identifiers of related resources. These must be globally unique identifiers.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/creatorName">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/creatorName.jsonld"/>
    <rdfs:label xml:lang="en">creatorName</rdfs:label>
    <rdfs:comment xml:lang="en">The full name of the creator.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/alternateIdentifierType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/alternateIdentifierType.jsonld"/>
    <rdfs:label xml:lang="en">alternateIdentifierType</rdfs:label>
    <rdfs:comment xml:lang="en">The type of the AlternateIdentifier.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/northBoundLatitude">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/northBoundLatitude.jsonld"/>
    <rdfs:label xml:lang="en">northBoundLatitude</rdfs:label>
    <rdfs:comment xml:lang="en">Northern latitudinal dimension of box.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/awardURI">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/awardURI.jsonld"/>
    <rdfs:label xml:lang="en">awardURI</rdfs:label>
    <rdfs:comment xml:lang="en">The URI leading to a page provided by the funder for more information about the award (grant).</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/eastBoundLongitude">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/eastBoundLongitude.jsonld"/>
    <rdfs:label xml:lang="en">eastBoundLongitude</rdfs:label>
    <rdfs:comment xml:lang="en">Eastern longitudinal dimension of box.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/firstPage">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/firstPage.jsonld"/>
    <rdfs:label xml:lang="en">firstPage</rdfs:label>
    <rdfs:comment xml:lang="en">First page of the resource within the related item, e.g., of the chapter, article, or conference paper in proceedings.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/publicationYear">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/publicationYear.jsonld"/>
    <rdfs:label xml:lang="en">publicationYear</rdfs:label>
    <rdfs:comment xml:lang="en">The year when the item was or will be made publicly available.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/identifierType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/identifierType.jsonld"/>
    <rdfs:label xml:lang="en">identifierType</rdfs:label>
    <rdfs:comment xml:lang="en">The type of Identifier.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/rights">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/rights.jsonld"/>
    <rdfs:label xml:lang="en">rights</rdfs:label>
    <rdfs:comment xml:lang="en">Any rights information for this resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relationType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/relationType.jsonld"/>
    <rdfs:label xml:lang="en">relationType</rdfs:label>
    <rdfs:comment xml:lang="en">Description of the relationship of the resource being registered (A) and the related resource (B).</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/volume">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/volume.jsonld"/>
    <rdfs:label xml:lang="en">volume</rdfs:label>
    <rdfs:comment xml:lang="en">Volume of the related item.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/polygonPoint">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/polygonPoint.jsonld"/>
    <rdfs:label xml:lang="en">polygonPoint</rdfs:label>
    <rdfs:comment xml:lang="en">A point location in a polygon.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/description">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/description.jsonld"/>
    <rdfs:label xml:lang="en">description</rdfs:label>
    <rdfs:comment xml:lang="en">All additional information that does not fit in any of the other categories. May be used for technical information or detailed information associated with a scientific instrument.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/contributor">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/contributor.jsonld"/>
    <rdfs:label xml:lang="en">contributor</rdfs:label>
    <rdfs:comment xml:lang="en">The institution or person responsible for collecting, managing, distributing, or otherwise contributing to the development of the resource. To supply multiple contributors, repeat this property.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/language">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/language.jsonld"/>
    <rdfs:label xml:lang="en">language</rdfs:label>
    <rdfs:comment xml:lang="en">The primary language of the resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/awardNumber">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/awardNumber.jsonld"/>
    <rdfs:label xml:lang="en">awardNumber</rdfs:label>
    <rdfs:comment xml:lang="en">The code assigned by the funder to a sponsored award (grant).</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/fundingReference">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/fundingReference.jsonld"/>
    <rdfs:label xml:lang="en">fundingReference</rdfs:label>
    <rdfs:comment xml:lang="en">Information about financial support (funding) for the resource being registered.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/contributorName">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/contributorName.jsonld"/>
    <rdfs:label xml:lang="en">contributorName</rdfs:label>
    <rdfs:comment xml:lang="en">The full name of the contributor.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/geoLocationPoint">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/geoLocationPoint.jsonld"/>
    <rdfs:label xml:lang="en">geoLocationPoint</rdfs:label>
    <rdfs:comment xml:lang="en">A point location in space.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/creator">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/creator.jsonld"/>
    <rdfs:label xml:lang="en">creator</rdfs:label>
    <rdfs:comment xml:lang="en">The main researchers involved in producing the data, or the authors of the publication, in priority order. For instruments this is the manufacturer or developer of the instrument. To supply multiple creators, repeat this property.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedMetadataScheme">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/relatedMetadataScheme.jsonld"/>
    <rdfs:label xml:lang="en">relatedMetadataScheme</rdfs:label>
    <rdfs:comment xml:lang="en">The name of the scheme.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/size">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/size.jsonld"/>
    <rdfs:label xml:lang="en">size</rdfs:label>
    <rdfs:comment xml:lang="en">Size (e.g., bytes, pages, inches, etc.) or duration (extent), e.g., hours, minutes, days, etc., of a resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/affiliation">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/affiliation.jsonld"/>
    <rdfs:label xml:lang="en">affiliation</rdfs:label>
    <rdfs:comment xml:lang="en">The organizational or institutional affiliation of the creator.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/rightsIdentifierScheme">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/rightsIdentifierScheme.jsonld"/>
    <rdfs:label xml:lang="en">rightsIdentifierScheme</rdfs:label>
    <rdfs:comment xml:lang="en">The name of the scheme.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/southBoundLatitude">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/southBoundLatitude.jsonld"/>
    <rdfs:label xml:lang="en">southBoundLatitude</rdfs:label>
    <rdfs:comment xml:lang="en">Southern latitude of box .</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/title">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/title.jsonld"/>
    <rdfs:label xml:lang="en">title</rdfs:label>
    <rdfs:comment xml:lang="en">A name or title by which a resource is known. May be the title of a dataset or the name of a piece of software or an instrument.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedItemIdentifierType">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/relatedItemIdentifierType.jsonld"/>
    <rdfs:label xml:lang="en">relatedItemIdentifierType</rdfs:label>
    <rdfs:comment xml:lang="en">The type of the Identifier for the related item.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/rightsURI">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/rightsURI.jsonld"/>
    <rdfs:label xml:lang="en">rightsURI</rdfs:label>
    <rdfs:comment xml:lang="en">The URI of the license.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/classificationCode">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/classificationCode.jsonld"/>
    <rdfs:label xml:lang="en">classificationCode</rdfs:label>
    <rdfs:comment xml:lang="en">The classification code used for the subject term in the subject scheme.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/affiliationIdentifierScheme">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/affiliationIdentifierScheme.jsonld"/>
    <rdfs:label xml:lang="en">affiliationIdentifierScheme</rdfs:label>
    <rdfs:comment xml:lang="en">The name of the affiliation identifier scheme</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/lastPage">
    <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/property/lastPage.jsonld"/>
    <rdfs:label xml:lang="en">lastPage</rdfs:label>
    <rdfs:comment xml:lang="en">Last page of the resource within the related item, e.g., of the chapter, article, or conference paper in proceedings.</rdfs:comment>
  </rdf:Property>
  <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral">
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Other">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:prefLabel xml:lang="en">Other</skos:prefLabel>
        <skos:notation>Other</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:definition xml:lang="en">If selected, supply a value for ResourceType.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Other.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Workflow">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">Computational workflows involving sequential operations made on data by wrapped software and may be specified in a format belonging to a workflow management system, such as Taverna (http://www.taverna.org.uk/).</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Workflow</skos:prefLabel>
        <skos:notation>Workflow</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:definition xml:lang="en">A structured series of steps which can be executed to produce a final outcome, allowing users a means to specify and enact their work in a more reproducible manner.</skos:definition>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Workflow.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Text">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:prefLabel xml:lang="en">Text</skos:prefLabel>
        <skos:notation>Text</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.5682/9786065914018</skos:example>
        <skos:definition xml:lang="en">A resource consisting primarily of words for reading that is not covered by any other textual resource type in this list.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Text.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/StudyRegistration">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">Includes pre-registrations, registered reports, and clinical trials. Study registrations are sometimes peer-reviewed and may include the hypothesis, expected results, study design, and/or analysis plan.
&lt;resourceType resourceTypeGeneral="StudyRegistration"&gt;Pre-registration&lt;/resourceType&gt;</skos:scopeNote>
        <skos:prefLabel xml:lang="en">StudyRegistration</skos:prefLabel>
        <skos:notation>StudyRegistration</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:definition xml:lang="en">A detailed, time-stamped description of a research plan, often openly shared in a registry or published in a journal before the study is conducted to lend accountability and transparency in the hypothesis generating and testing process.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/StudyRegistration.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Standard">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">&lt;resourceType resourceTypeGeneral="Standard"&gt;Dublin Core&lt;/resourceType&gt;</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Standard</skos:prefLabel>
        <skos:notation>Standard</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:definition xml:lang="en">Something established by authority, custom, or general consent as a model, example, or point of reference.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Standard.jsonld"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Sound">
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote xml:lang="en">Audio recording</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Sound</skos:prefLabel>
        <skos:notation>Sound</skos:notation>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.7282/T3J67F05</skos:example>
        <skos:definition xml:lang="en">A resource primarily intended to be heard.</skos:definition>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Sound"/>
        <rdfs:seeAlso rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Sound.jsonld"/>
