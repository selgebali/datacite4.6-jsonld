  "prefLabel": "HasVersion",
  "notation": "HasVersion",
  "definition": "indicates A has a version B",
  "inScheme": "https://schema.stage.datacite.org/linked-data/vocab/datacite-4.6/relationType",
  "topConceptOf": "https://schema.stage.datacite.org/linked-data/vocab/datacite-4.6/relationType",
  "scopeNote": "The registered resource such as a software package or code repository has a versioned instance (A has instance B). May relate an un-versioned code repository to a specific software version.",
